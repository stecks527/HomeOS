/*************************************************
 * 10 HOMEOS - API
 * Version: 4.0.0
 * Status: ACTIVE
 *
 * Canonical public API for Home / Mission Control.
 *************************************************/

function HomeOS() {
  return {
    /*************************************************
     * UI
     *************************************************/

    open: function () {
      return homeOSRefresh_();
    },

    /*************************************************
     * STATE
     *************************************************/

    current: function () {
      return homeOSGetCurrentState_();
    },

    get: function () {
      return homeOSGetCurrentState_();
    },

    /*************************************************
     * REFRESH
     *************************************************/

    refresh: function () {
      return homeOSRefresh_();
    },

    /*************************************************
     * CACHE
     *************************************************/

    clearCache: function () {
      return homeOSClearCaches_();
    },

    clearAllCaches: function () {
      return homeOSClearAllCaches_();
    },

    /*************************************************
     * HEALTH
     *************************************************/

    status: function () {
      return homeOSStatus_();
    },

    test: function () {
      return testHomeOSPlatformAPI();
    }
  };
}

/*************************************************
 * CANONICAL REFRESH
 *************************************************/

function homeOSRefresh_() {
  return refreshStageOSDashboard_HOMEV2();
}

function refreshHome() {
  return HomeOS().refresh();
}

function refreshStageOSHome() {
  return HomeOS().refresh();
}

function testHomeOSRefresh() {
  return HomeOS().refresh();
}

