/*************************************************
 * PAYROLL SYNC RESULT MESSAGE
 *************************************************/

function buildHomePayrollSyncResultMessage_(result) {

  result = result || {};

  const lines = [
    "✓ Current Payroll Notes updated",
    "✓ Payroll grid left editable and unchanged",
    ""
  ];

  if (result.weeklySheet) {
    lines.push(
      "Weekly source: " +
      result.weeklySheet
    );
  }

  if (
    result.weekStart ||
    result.weekEnd
  ) {
    lines.push(
      "Week: " +
      String(result.weekStart || "") +
      " through " +
      String(result.weekEnd || "")
    );
  }

  if (
    result.notesCell
  ) {
    lines.push(
      "Notes written to: " +
      result.notesCell
    );
  }

  if (
    result.outPerformances != null
  ) {
    lines.push(
      "OUT performances: " +
      result.outPerformances
    );
  }

  if (
    result.coveragePerformances != null
  ) {
    lines.push(
      "Coverage performances: " +
      result.coveragePerformances
    );
  }

  if (
    result.missingCoveragePerformances != null
  ) {
    lines.push(
      "Missing coverage: " +
      result.missingCoveragePerformances
    );
  }

  if (
    result.durationMs != null
  ) {
    lines.push(
      "Completed in " +
      result.durationMs +
      " ms"
    );
  }

  return lines.join("\n");
}

function getHomePayrollSyncResultNumber_(
  result,
  possibleKeys
) {
  for (
    let i = 0;
    i < possibleKeys.length;
    i++
  ) {
    const key = possibleKeys[i];

    if (
      Object.prototype.hasOwnProperty.call(
        result,
        key
      )
    ) {
      const value = Number(result[key]);

      if (!isNaN(value)) {
        return value;
      }
    }
  }

  return null;
}


