/* =========================================================
 * TASK RICH TEXT
 * ========================================================= */

function buildHomeV2LongTermTaskRichText_(
  task
) {
  task =
    task || {};

  const theme =
    getHomeV2Theme_();

  const title =
    String(
      task.task || ""
    ).trim();

  const due =
    String(
      task.dueDate || ""
    ).trim();

  const note =
    String(
      task.note || ""
    ).trim();

  const lines = [
    title
  ];

  if (due) {
    lines.push(
      "Due: " +
      due
    );
  }

  if (note) {
    lines.push(
      note
    );
  }

  const text =
    lines.join(
      "\n"
    );

  const builder =
    SpreadsheetApp
      .newRichTextValue()
      .setText(
        text
      );

  const titleStyle =
    SpreadsheetApp
      .newTextStyle()
      .setFontFamily(
        HOME_V2.FONT
      )
      .setFontSize(12)
      .setBold(true)
      .setForegroundColor(
        "#111111"
      )
      .build();

  const dueStyle =
    SpreadsheetApp
      .newTextStyle()
      .setFontFamily(
        HOME_V2.FONT
      )
      .setFontSize(9)
      .setBold(true)
      .setForegroundColor(
        theme.primaryColor
      )
      .build();

  const noteStyle =
    SpreadsheetApp
      .newTextStyle()
      .setFontFamily(
        HOME_V2.FONT
      )
      .setFontSize(9)
      .setBold(false)
      .setForegroundColor(
        theme.mutedText
      )
      .build();

  if (title) {
    builder.setTextStyle(
      0,
      title.length,
      titleStyle
    );
  }

  if (due) {
    const dueText =
      "Due: " +
      due;

    const start =
      text.indexOf(
        dueText
      );

    if (start >= 0) {
      builder.setTextStyle(
        start,
        start +
          dueText.length,
        dueStyle
      );
    }
  }

  if (note) {
    const start =
      text.lastIndexOf(
        note
      );

    if (start >= 0) {
      builder.setTextStyle(
        start,
        start +
          note.length,
        noteStyle
      );
    }
  }

  return builder.build();
}


/* =========================================================
 * LONG-TERM CARD BORDERS
 * ========================================================= */

function styleHomeV2LongTermCard_(
  sh,
  startRow,
  numRows
) {
  const theme =
    getHomeV2Theme_();

  const range =
    sh.getRange(
      startRow,
      HOME_V2.FULL_COL,
      numRows,
      HOME_V2.FULL_WIDTH
    );

  /*
   * Remove inherited internal vertical rules.
   */
  range.setBorder(
    false,
    false,
    false,
    false,
    false,
    false
  );

  /*
   * Keep horizontal row separators.
   */
  range.setBorder(
    false,
    false,
    false,
    false,
    false,
    true,
    theme.borderColor,
    SpreadsheetApp.BorderStyle.SOLID
  );

  /*
   * Strong outer frame.
   */
  range.setBorder(
    true,
    true,
    true,
    true,
    null,
    null,
    theme.borderColor,
    SpreadsheetApp.BorderStyle.SOLID_MEDIUM
  );

  /*
   * Strong divider below the blue title.
   */
  sh.getRange(
    startRow,
    HOME_V2.FULL_COL,
    1,
    HOME_V2.FULL_WIDTH
  )
    .setBorder(
      null,
      null,
      true,
      null,
      false,
      false,
      theme.borderColor,
      SpreadsheetApp.BorderStyle.SOLID_MEDIUM
    );
