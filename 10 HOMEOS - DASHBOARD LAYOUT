function homeV2AddLongTermTask(payload) {
  payload = payload || {};

  const task = String(payload.task || "").trim();
  const dueDate = String(payload.dueDate || "").trim();
  const note = String(payload.note || "").trim();

  if (!task) {
    throw new Error("Task is required.");
