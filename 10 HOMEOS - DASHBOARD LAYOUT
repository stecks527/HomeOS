function buildHomeV2HeroBody_(showState) {
  const pieces = [];

  getHomeV2Performances_(showState).forEach(function (perf) {
    const number = perf.number || perf.performanceNumber || "";
    const time = perf.time || perf.performanceTime || "";

    if (number && time) {
      pieces.push("Performance #" + number + " • " + time);
    } else if (number) {
      pieces.push("Performance #" + number);
    } else if (time) {
      pieces.push(time);
    }
  });

  buildHomeV2RehearsalHeadlineItems_(showState).forEach(function (item) {
    if (item) pieces.push(item);
  });

  return pieces.length ? pieces.join("  •  ") : "No performance or rehearsal selected";
}

function buildHomeV2RehearsalHeadlineItems_(showState) {
  const notes = normalizeHomeV2Notes_(showState.notes);
  if (!notes) return [];

  const lines = notes
    .split(/\n+/)
    .map(function (line) {
      return line.replace(/^[-•]\s*/, "").trim();
    })
    .filter(Boolean);

  return lines.filter(function (line) {
    const upper = line.toUpperCase();

    if (upper.includes("PRESS")) return false;
    if (upper.includes("FILMING")) return false;
    if (upper.includes("PHOTO")) return false;
    if (upper.includes("PT ")) return false;

    return (
      upper.includes("REHEARSAL") ||
      upper.includes("BRUSH-UP") ||
      upper.includes("BRUSH UP") ||
      upper.includes("PUT-IN") ||
      upper.includes("PUT IN") ||
      upper.includes("UNDERSTUDY")
    );
  }).slice(0, 3);
}

