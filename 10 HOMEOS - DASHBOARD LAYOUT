function refreshHomeTimelineHighlightFromTrigger_() {
  const spreadsheetId = PropertiesService
    .getScriptProperties()
    .getProperty("HOME_TIMELINE_SPREADSHEET_ID");

  if (!spreadsheetId) return;

  const ss = SpreadsheetApp.openById(spreadsheetId);
  const home = ss.getSheetByName("Home");
  const inOut = ss.getSheetByName("IN/OUT");

  if (!home || !inOut) return;

  refreshHomeTimelineHighlightOnly_(home, inOut);
}

function refreshHomeTimelineHighlightOnly_(home, inOut) {
  const selectedDate = homeV2ReadSelectedDateForTrigger_(inOut);
  if (!selectedDate) return;

  const now = new Date(selectedDate);
  const realNow = new Date();

  now.setHours(
    realNow.getHours(),
    realNow.getMinutes(),
    realNow.getSeconds(),
    realNow.getMilliseconds()
  );

  const timeline = homeV2FindTimelineRows_(home);
  if (!timeline.rows.length) return;

  const timedRows = timeline.rows
    .map(function (rowInfo) {
      const eventTime = homeV2BuildTimelineDateTime_(
        selectedDate,
        rowInfo.timeText
      );

      return {
        row: rowInfo.row,
        timeText: rowInfo.timeText,
        time: eventTime
      };
    })
    .filter(function (item) {
      return item.time instanceof Date && !isNaN(item.time.getTime());
    })
    .sort(function (a, b) {
      return a.time.getTime() - b.time.getTime();
    });

  if (!timedRows.length) return;

  let activeTime = null;

  timedRows.forEach(function (item) {
    if (item.time.getTime() <= now.getTime()) {
      activeTime = item.time.getTime();
    }
  });

  timedRows.forEach(function (item) {
    const range = home.getRange(item.row, 6, 1, 4);
    const itemTime = item.time.getTime();

    if (activeTime !== null && itemTime === activeTime) {
      // Current event
      range
        .setBackground(HOME_V2.DEFAULT_SECONDARY)
        .setFontColor("#111111")
        .setFontWeight("bold");

    } else if (itemTime < now.getTime()) {
      // Past event
      range
        .setBackground(HOME_V2.DEFAULT_PAST_BG)
        .setFontColor("#999999")
        .setFontWeight("normal");

    } else {
      // Future event
      range
        .setBackground("#FFFFFF")
        .setFontColor("#111111")
        .setFontWeight("normal");
    }
  });
}

function homeV2FindTimelineRows_(home) {
  const lastRow = Math.min(home.getLastRow(), HOME_V2.MAX_ROWS);
  if (lastRow < 2) return { headerRow: 0, rows: [] };

  const values = home
    .getRange(1, 6, lastRow, 4)
    .getDisplayValues();

  let headerIndex = -1;

  for (let i = 0; i < values.length; i++) {
    const timeHeader = String(values[i][0] || "")
      .trim()
      .toUpperCase();

    const eventHeader = String(values[i][1] || "")
      .trim()
      .toUpperCase();

    const whoHeader = String(values[i][3] || "")
      .trim()
      .toUpperCase();

    if (
      timeHeader === "TIME" &&
      eventHeader === "EVENT" &&
      whoHeader === "WHO"
    ) {
      headerIndex = i;
      break;
    }
  }

  if (headerIndex === -1) {
    return { headerRow: 0, rows: [] };
  }

  const rows = [];

  for (let i = headerIndex + 1; i < values.length; i++) {
    const timeText = String(values[i][0] || "").trim();
    const eventText = String(values[i][1] || "").trim();
    const whoText = String(values[i][3] || "").trim();

    // Timeline ends at the first fully blank row.
    if (!timeText && !eventText && !whoText) {
      break;
    }

    // Ignore anything that is not a timed timeline entry.
    if (!timeText) continue;

    rows.push({
      row: i + 1,
      timeText: timeText
    });
  }

  return {
    headerRow: headerIndex + 1,
    rows: rows
  };
}

function homeV2ReadSelectedDateForTrigger_(inOut) {
  const value = inOut.getRange("A3").getValue();

  if (
    Object.prototype.toString.call(value) === "[object Date]" &&
    !isNaN(value.getTime())
  ) {
    return new Date(
      value.getFullYear(),
      value.getMonth(),
      value.getDate()
    );
  }

  const display = String(
    inOut.getRange("A3").getDisplayValue() || ""
  ).trim();

  if (!display) return null;

  const parsed = new Date(display);
  if (isNaN(parsed.getTime())) return null;

  return new Date(
    parsed.getFullYear(),
    parsed.getMonth(),
    parsed.getDate()
  );
}

function homeV2BuildTimelineDateTime_(date, timeText) {
  if (!(date instanceof Date)) return null;

  const text = String(timeText || "")
    .trim()
    .toUpperCase();

  const match = text.match(
    /^(\d{1,2})(?::(\d{2}))?\s*(AM|PM)?$/
  );

  if (!match) return null;

  let hour = Number(match[1]);
  const minute = match[2] ? Number(match[2]) : 0;
  const ampm = String(match[3] || "").toUpperCase();

  if (ampm === "PM" && hour !== 12) hour += 12;
  if (ampm === "AM" && hour === 12) hour = 0;

  const result = new Date(date);
  result.setHours(hour, minute, 0, 0);

  return result;
}

