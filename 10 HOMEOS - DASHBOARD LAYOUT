    getHomeV2Theme_();

  const title =
    String(
      task.task || ""
    ).trim();

  const due =
    String(
      task.dueDate || ""
    ).trim();

  const note =
    String(
      task.note || ""
    ).trim();

  const lines = [
    title
  ];

  if (due) {
    lines.push(
      "Due: " +
      due
    );
  }

  if (note) {
    lines.push(
      note
    );
  }

  const text =
    lines.join(
      "\n"
    );

  const builder =
    SpreadsheetApp
      .newRichTextValue()
      .setText(
        text
      );

  const titleStyle =
    SpreadsheetApp
      .newTextStyle()
      .setFontFamily(
        HOME_V2.FONT
      )
      .setFontSize(12)
      .setBold(true)
      .setForegroundColor(
        "#111111"
      )
      .build();

  const dueStyle =
    SpreadsheetApp
      .newTextStyle()
      .setFontFamily(
        HOME_V2.FONT
      )
      .setFontSize(9)
      .setBold(true)
      .setForegroundColor(
        theme.primaryColor
      )
      .build();

  const noteStyle =
    SpreadsheetApp
      .newTextStyle()
      .setFontFamily(
        HOME_V2.FONT
      )
      .setFontSize(9)
      .setBold(false)
      .setForegroundColor(
        theme.mutedText
      )
      .build();

  if (title) {
    builder.setTextStyle(
      0,
      title.length,
      titleStyle
    );
  }

  if (due) {
    const dueText =
      "Due: " +
      due;

    const start =
      text.indexOf(
        dueText
      );

    if (start >= 0) {
      builder.setTextStyle(
        start,
        start +
          dueText.length,
        dueStyle
      );
    }
  }

  if (note) {
    const start =
      text.lastIndexOf(
        note
      );

    if (start >= 0) {
      builder.setTextStyle(
        start,
        start +
          note.length,
        noteStyle
      );
    }
  }

  return builder.build();
}


