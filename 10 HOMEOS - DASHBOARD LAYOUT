function homeV2AddLongTermTask(payload) {
  payload = payload || {};

  const task = String(payload.task || "").trim();
  const dueDate = String(payload.dueDate || "").trim();
  const note = String(payload.note || "").trim();

  if (!task) {
    throw new Error("Task is required.");
  }

  const ss = SpreadsheetApp.getActive();
  const sh = ss.getSheetByName("Long-Term Tasks") || ss.insertSheet("Long-Term Tasks");

  if (sh.getLastRow() === 0) {
    sh.getRange(1, 1, 1, 4).setValues([[
      "Task",
      "Due Date",
      "Note",
      "Status"
    ]]);
  }

  sh.appendRow([
    task,
    dueDate,
    note,
    "Open"
  ]);

  refreshStageOSDashboard_V2();

  return {
    success: true,
    message: "Long-term task added."
  };
}

