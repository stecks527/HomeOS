function drawHomeV2Hero_(
  sh,
  row,
  showState
) {
  const theme =
    getHomeV2Theme_();

  const heroColor =
    getHomeV2HeroColor_();

  const title =
    theme.productionName;

  const date =
    showState.prettyDate ||
    showState.date ||
    "";

  const heroBody =
    buildHomeV2HeroBody_(
      showState
    );

  const range =
    sh.getRange(
      row,
      HOME_V2.FULL_COL,
      HOME_V2.HERO_ROWS,
      HOME_V2.FULL_WIDTH
    );

  range
    .merge()
    .setValue(
      [
        title,
        "",
        date,
        "",
        heroBody
      ].join("\n")
    )
    .setBackground(
      heroColor
    )
    .setFontColor(
      "#FFFFFF"
    )
    .setFontWeight(
      "bold"
    )
    .setHorizontalAlignment(
      "center"
    )
    .setVerticalAlignment(
      "middle"
    )
    .setWrap(true)
    .setFontSize(18)
    .setBorder(
      true,
      true,
      true,
      true,
      false,
      false,
      theme.primaryColor,
      SpreadsheetApp.BorderStyle.SOLID_MEDIUM
    );

  sh.setRowHeight(row, 42);
  sh.setRowHeight(row + 1, 22);
  sh.setRowHeight(row + 2, 38);
  sh.setRowHeight(row + 3, 20);
  sh.setRowHeight(row + 4, 44);

  return (
    row +
    HOME_V2.HERO_ROWS +
    HOME_V2.GAP_ROWS
  );
}

function buildHomeV2HeroDayLine_(showState) {
  return buildHomeV2HeroBody_(showState);
}

function buildHomeV2HeroBody_(showState) {
  const pieces = [];

  getHomeV2Performances_(showState).forEach(function (perf) {
    const number = perf.number || perf.performanceNumber || "";
    const time = perf.time || perf.performanceTime || "";

    if (number && time) {
      pieces.push("Performance #" + number + " • " + time);
    } else if (number) {
      pieces.push("Performance #" + number);
    } else if (time) {
      pieces.push(time);
    }
  });

  buildHomeV2RehearsalHeadlineItems_(showState).forEach(function (item) {
    if (item) pieces.push(item);
  });

  return pieces.length ? pieces.join("  •  ") : "No performance or rehearsal selected";
}

function buildHomeV2RehearsalHeadlineItems_(showState) {
  const notes = normalizeHomeV2Notes_(showState.notes);
  if (!notes) return [];

  const lines = notes
    .split(/\n+/)
    .map(function (line) {
      return line.replace(/^[-•]\s*/, "").trim();
    })
    .filter(Boolean);

  return lines.filter(function (line) {
    const upper = line.toUpperCase();

    if (upper.includes("PRESS")) return false;
    if (upper.includes("FILMING")) return false;
    if (upper.includes("PHOTO")) return false;
    if (upper.includes("PT ")) return false;

    return (
      upper.includes("REHEARSAL") ||
      upper.includes("BRUSH-UP") ||
      upper.includes("BRUSH UP") ||
      upper.includes("PUT-IN") ||
      upper.includes("PUT IN") ||
      upper.includes("UNDERSTUDY")
    );
  }).slice(0, 3);
}

/*************************************************
 * HOMEOS V2 - STATUS STRIP DOUBLE BORDER
 * Version: 1.0.0
 *
 * In 06v HOMEOS V2 LAYOUT.gs:
 *
 * Replace only:
 *   drawHomeV2HeadlineStrip_
 *
 * Keep:
 *   buildHomeV2HeadlineStripItems_
 * exactly as it is.
