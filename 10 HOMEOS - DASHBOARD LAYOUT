function drawHomeV2Notes_(
  sh,
  row,
  showState
) {
  const notes =
    normalizeHomeV2Notes_(
      showState.notes
    );

  if (!notes) {
    return row;
  }

  const theme =
    getHomeV2Theme_();

  const startRow =
    row;

  row =
    drawHomeV2CardTitle_(
      sh,
      row,
      HOME_V2.FULL_COL,
      HOME_V2.FULL_WIDTH,
      "NOTES"
    );

  const noteRows =
    Math.max(
      2,
      Math.min(
        7,
        notes.split("\n").length +
        1
      )
    );

  sh.getRange(
    row,
    HOME_V2.FULL_COL,
    noteRows,
    HOME_V2.FULL_WIDTH
  )
    .merge()
    .setValue(
      notes
    )
    .setFontSize(13)
    .setVerticalAlignment("top")
    .setHorizontalAlignment("left")
    .setBackground(
      theme.noteBackground
    );

  sh.setRowHeights(
    row,
    noteRows,
    30
  );

  row +=
    noteRows;

  fillHomeV2CardBody_(
    sh,
    startRow + 1,
    HOME_V2.FULL_COL,
    row - startRow - 1,
    HOME_V2.FULL_WIDTH
  );

  styleHomeV2Card_(
    sh,
    startRow,
    HOME_V2.FULL_COL,
    row - startRow,
    HOME_V2.FULL_WIDTH
  );

  return (
    row +
    HOME_V2.GAP_ROWS
  );
}

/*************************************************
 * HOMEOS TASK CARDS + HOME INTELLIGENCE
 * Version: 2.6.0
 * Status: ACTIVE
 *
 * Complete replacement chunk.
 *
 * Replace the entire current section beginning at:
 *   HOMEOS TASK CARDS
 *
 * Stop immediately before:
 *   CHUNK 7 — TIMELINE ITEMS FROM NOTES
 *
 * Task display model:
 * {
 *   title: "Main task",
 *   details: ["Detail one", "Detail two"],
 *   footnote: "Optional note"
 * }
 *
 * The renderer owns bullets, spacing, sizes, and styles.
 *************************************************/

function drawHomeV2Tasks_(
  sh,
  row,
  showState
) {
  const startRow =
    row;

  clearHomeTaskContextCache_();

  HOME_TASK_CONTEXT_CACHE_ = {
    showState:
      showState || {},

    snapshotId:
      buildHomeSnapshotIdFromShowState_(
        showState || {}
      ),

    hasGuestSpeller:
      homeV2HasGuestSpeller_(
        showState || {}
      ),

    insertLineCount:
      getHomeV2PrincipalOuts_(
        showState || {}
      ).length
  };

  /*
   * Blue card titles.
   */
  drawHomeV2CardTitle_(
    sh,
    row,
    HOME_V2.LEFT_COL,
    HOME_V2.LEFT_WIDTH,
    "TODAY'S TASKS"
  );

  drawHomeV2CardTitle_(
    sh,
    row,
    HOME_V2.RIGHT_COL,
    HOME_V2.RIGHT_WIDTH,
    "WEEKLY TASKS"
  );

  row++;

  /*
   * DONE | TASK | RUN headings.
   */
  drawHomeV2TaskHeaders_(
    sh,
    row,
    HOME_V2.LEFT_COL,
    HOME_V2.LEFT_WIDTH
  );

  drawHomeV2TaskHeaders_(
    sh,
    row,
    HOME_V2.RIGHT_COL,
    HOME_V2.RIGHT_WIDTH
  );

  row++;

  const todayTasks =
    buildHomeTodayTasks_();

  const weeklyTasks =
    buildHomeWeeklyTasks_();

  const todayRows =
    drawHomeV2TaskList_(
      sh,
      row,
      HOME_V2.LEFT_COL,
      HOME_V2.LEFT_WIDTH,
      todayTasks,
      showState
    );

  const weeklyRows =
    drawHomeV2TaskList_(
      sh,
      row,
      HOME_V2.RIGHT_COL,
      HOME_V2.RIGHT_WIDTH,
      weeklyTasks,
      showState
    );

  const taskRows =
    Math.max(
      todayRows,
      weeklyRows,
      1
    );

  /*
   * Header row plus all task rows.
   */
  const bodyRows =
    taskRows + 1;

  fillHomeV2CardBody_(
    sh,
    startRow + 1,
    HOME_V2.LEFT_COL,
    bodyRows,
    HOME_V2.LEFT_WIDTH
  );

  fillHomeV2CardBody_(
    sh,
    startRow + 1,
    HOME_V2.RIGHT_COL,
    bodyRows,
    HOME_V2.RIGHT_WIDTH
  );

  /*
   * Reapply the lighter RUN-column background after the
   * card-body fill.
   */
  sh.getRange(
    startRow + 1,
    HOME_V2.LEFT_COL + HOME_V2.LEFT_WIDTH - 1,
    bodyRows,
    1
  )
    .setBackground(
      "#F6F8FC"
    );

  sh.getRange(
    startRow + 1,
    HOME_V2.RIGHT_COL + HOME_V2.RIGHT_WIDTH - 1,
    bodyRows,
    1
  )
    .setBackground(
      "#F6F8FC"
    );

  /*
   * Separate card borders with horizontal row rules only.
   */
  styleHomeV2TaskCard_(
    sh,
    startRow,
    HOME_V2.LEFT_COL,
    bodyRows + 1,
    HOME_V2.LEFT_WIDTH
  );

  styleHomeV2TaskCard_(
    sh,
    startRow,
    HOME_V2.RIGHT_COL,
    bodyRows + 1,
    HOME_V2.RIGHT_WIDTH
  );

  return (
    startRow +
    bodyRows +
    1 +
    HOME_V2.GAP_ROWS
  );
}

function styleHomeV2TaskCard_(
  sh,
  startRow,
  startCol,
  numRows,
  numCols
) {
  const theme =
    getHomeV2Theme_();

  const cardRange =
    sh.getRange(
      startRow,
      startCol,
      numRows,
      numCols
    );

  /*
   * Remove all internal gridlines first.
   */
  cardRange.setBorder(
    false,
    false,
    false,
    false,
    false,
    false
  );

  /*
   * Light horizontal dividers between rows.
   * No internal vertical rules.
   */
  cardRange.setBorder(
    false,  // top
    false,  // left
    false,  // bottom
    false,  // right
    false,  // vertical
    true,   // horizontal
    theme.borderColor,
    SpreadsheetApp.BorderStyle.SOLID
  );

  /*
   * Stronger outside frame around the full card.
   */
  cardRange.setBorder(
    true,
    true,
    true,
    true,
    null,
    null,
    theme.borderColor,
    SpreadsheetApp.BorderStyle.SOLID_MEDIUM
  );

  /*
   * A slightly stronger divider under the blue title row.
   */
  sh.getRange(
    startRow,
    startCol,
    1,
    numCols
  )
    .setBorder(
      null,
      null,
      true,
      null,
      false,
      false,
      theme.borderColor,
      SpreadsheetApp.BorderStyle.SOLID_MEDIUM
    );
}

function drawHomeV2TaskHeaders_(
