/*************************************************
 * MAIN REFRESH
 *************************************************/

function refreshStageOSDashboard_V2() {
  HOME_V2_THEME_CACHE_ = null;
  HOME_WORKFLOW_STATUS_CACHE_ = null;

  const ss = SpreadsheetApp.getActive();
  let sh = ss.getSheetByName(HOME_V2.SHEET_NAME);

  if (!sh) {
    sh = ss.insertSheet(HOME_V2.SHEET_NAME, 0);
  }

  const ctx = buildHomeContext_();
  HOME_CURRENT_CONTEXT_ = null;

  const showState = ctx.showState || {};
  const timeline = ctx.timeline || {};

  setupHomeV2Sheet_(sh);

  let row = 1;

  row = drawHomeV2Hero_(sh, row, showState);
  row = drawHomeV2HeadlineStrip_(sh, row, showState);
  row = drawHomeV2TodayAndTimeline_(sh, row, showState, timeline);
  row = drawHomeV2TodayCompany_(sh, row, showState);
  row = drawHomeV2Notes_(sh, row, showState);
  row = drawHomeV2Tasks_(sh, row, showState);
  row = drawHomeV2LongTermAndUpcoming_(sh, row);

  /*
  * Operations utilities.
  * Kept below Upcoming so they do not repeat the
  * workflow actions already shown in Today's Tasks.
  */
  row = drawHomeV2UtilitiesCard_(sh, row);

  /*
   * Full editable PT workspace.
   * Shows today's PT session or the next scheduled session.
   * Placed below Upcoming because PT is useful but not
   * always high-priority information.
   */
  row = drawHomeV2PTCard_(sh, row, showState);

  finishHomeV2Sheet_(sh);

  sh.getRange("A1").activate();
}

/*************************************************
 * SHEET SETUP
 *************************************************/

function setupHomeV2Sheet_(sh) {
  sh.setFrozenRows(0);
  sh.setFrozenColumns(0);
  sh.setHiddenGridlines(true);

  const range = sh.getRange(1, 1, HOME_V2.MAX_ROWS, HOME_V2.MAX_COLS);

  // Clear only the active Home canvas.
  range.breakApart();
  range.clearContent();
  range.clearFormat();
  range.clearDataValidations();
  range.clearNote();

  sh.clearConditionalFormatRules();

  const widths = [80, 135, 170, 170, 24, 90, 155, 155, 155];

  widths.forEach(function(width, index) {
    if (sh.getColumnWidth(index + 1) !== width) {
      sh.setColumnWidth(index + 1, width);
    }
  });

  range
    .setFontFamily(HOME_V2.FONT)
    .setFontSize(12)
    .setVerticalAlignment("middle")
    .setWrap(true)
    .setFontLine("none")
    .setBackground(HOME_V2.DEFAULT_BG);

  // Faster than 180 individual setRowHeight calls.
  sh.setRowHeights(1, HOME_V2.MAX_ROWS, HOME_V2.NORMAL_ROW_HEIGHT);
}

function finishHomeV2Sheet_(sh) {
  sh.setFrozenRows(0);
  sh.setFrozenColumns(0);
  sh.setHiddenGridlines(true);
}

