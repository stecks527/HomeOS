function setupHomeV2Sheet_(sh) {
  sh.setFrozenRows(0);
  sh.setFrozenColumns(0);
  sh.setHiddenGridlines(true);

  const range = sh.getRange(1, 1, HOME_V2.MAX_ROWS, HOME_V2.MAX_COLS);

  // Clear only the active Home canvas.
  range.breakApart();
  range.clearContent();
  range.clearFormat();
  range.clearDataValidations();
  range.clearNote();

  sh.clearConditionalFormatRules();

  const widths = [80, 135, 170, 170, 24, 90, 155, 155, 155];

  widths.forEach(function(width, index) {
    if (sh.getColumnWidth(index + 1) !== width) {
      sh.setColumnWidth(index + 1, width);
    }
  });

  range
    .setFontFamily(HOME_V2.FONT)
    .setFontSize(12)
    .setVerticalAlignment("middle")
    .setWrap(true)
    .setFontLine("none")
    .setBackground(HOME_V2.DEFAULT_BG);

  // Faster than 180 individual setRowHeight calls.
