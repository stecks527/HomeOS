  return getHomeV2CastOuts_(showState).filter(function (item) {
    item = item || {};

    const out = String(item.out || item.Out || "").trim();
    const role = String(item.role || item.Role || "").toLowerCase();

    if (!out) return false;

    if (
      role.includes("swing") ||
      role.includes("understudy") ||
      role.includes("u/s") ||
      role.includes("standby")
    ) {
      return false;
    }

    return true;
  });
}

