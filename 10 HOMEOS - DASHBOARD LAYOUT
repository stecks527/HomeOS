function styleHomeV2Card_(sh, startRow, startCol, numRows, numCols) {
  const theme = getHomeV2Theme_();

  const range = sh.getRange(startRow, startCol, numRows, numCols);

  // Do NOT reset the whole card background here.
  // That was wiping out blue section headers.
  range.setBorder(
    true,
    true,
    true,
    true,
    true,
    true,
    theme.borderColor,
    SpreadsheetApp.BorderStyle.SOLID
  );

  // Slightly stronger outside border.
  range.setBorder(
    true,
    true,
    true,
    true,
    null,
    null,
    theme.borderColor,
    SpreadsheetApp.BorderStyle.SOLID_MEDIUM
  );
}

function styleHomeV2OuterCardOnly_(sh, startRow, startCol, numRows, numCols) {
