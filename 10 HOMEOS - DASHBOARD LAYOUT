function drawHomeV2HeadlineStrip_(
  sh,
  row,
  showState
) {
  const theme =
    getHomeV2Theme_();

  const items =
    buildHomeV2HeadlineStripItems_(
      showState
    );

  if (!items.length) {
    return row;
  }

  const range =
    sh.getRange(
      row,
      HOME_V2.FULL_COL,
      HOME_V2.STRIP_ROWS,
      HOME_V2.FULL_WIDTH
    );

  range
    .merge()
    .setValue(
      items.join(
        "   •   "
      )
    )
    .setBackground(
      theme.cardColor
    )
    .setFontColor(
      "#111111"
    )
    .setFontWeight(
      "bold"
    )
    .setFontSize(13)
    .setHorizontalAlignment(
      "center"
    )
    .setVerticalAlignment(
      "middle"
    )
    .setWrap(true);

  /*
   * Keep the side edges clean and connected to the page.
   */
  range.setBorder(
    false,  // top
    true,   // left
    false,  // bottom
    true,   // right
    false,  // vertical
    false,  // horizontal
    theme.primaryColor,
    SpreadsheetApp.BorderStyle.SOLID
  );

  /*
   * Strong double rules above and below the status line.
   */
  range.setBorder(
    true,   // top
    null,   // left unchanged
    true,   // bottom
    null,   // right unchanged
    false,  // vertical
    false,  // horizontal
    theme.primaryColor,
    SpreadsheetApp.BorderStyle.DOUBLE
  );

  sh.setRowHeight(
    row,
    42
  );

  return (
    row +
    HOME_V2.STRIP_ROWS +
    HOME_V2.GAP_ROWS
  );
}

function buildHomeV2HeadlineStripItems_(
  showState
) {
  const items = [];

  const principalOuts =
    getHomeV2PrincipalOuts_(
      showState
    );

  if (
    principalOuts.length
  ) {
    items.push(
      principalOuts.length +
      " Principal Out" +
      (
        principalOuts.length === 1
          ? ""
          : "s"
      )
    );
  }

  const conductor =
    getHomeConductorFromShowState_(
      showState
    );

  if (conductor) {
    items.push(
      "Conductor: " +
      conductor
    );
  }

  const guest =
    getHomeGuestSpellerFromShowState_(
      showState
    );

  if (guest) {
    items.push(
      "Guest Speller: " +
      guest
    );
  }

  const notes =
    normalizeHomeV2Notes_(
      showState &&
      showState.notes
    );

  const notesUpper =
    notes.toUpperCase();

  if (
    notesUpper.includes(
      "OFFICE SHOW"
    )
  ) {
    items.push(
      "Office Show"
    );
  }

  const pressItem =
    getHomeV2PressHeadlineItem_(
      notes
    );

  if (pressItem) {
    items.push(
      pressItem
    );
  }

  return items;
}


function getHomeV2PressHeadlineItem_(
  notes
) {
  const lines =
    String(notes || "")
      .split(/\n+/)
      .map(
        function (line) {
          return String(
            line || ""
          )
            .replace(
              /^[-•]\s*/,
              ""
            )
            .trim();
        }
      )
      .filter(Boolean);

  for (
    let index = 0;
    index < lines.length;
    index++
  ) {
    const line =
      lines[index];

    const upper =
      line.toUpperCase();

    const isPress =
      upper.includes("PRESS") ||
      upper.includes("FILM") ||
      upper.includes("SOCIAL MEDIA") ||
      upper.includes("VIDEO");

    if (!isPress) {
      continue;
    }

    const timeMatch =
      line.match(
        /\b\d{1,2}(?::\d{2})?\s*(?:AM|PM)\b/i
      );

    const timeText =
      timeMatch
        ? timeMatch[0]
            .toUpperCase()
            .replace(
              /^(\d{1,2})(AM|PM)$/,
              "$1:00 $2"
            )
        : "";

    return timeText
      ? (
          "Press / Social Media Event: " +
          timeText
        )
      : "Press / Social Media Event";
  }

  return "";
}

function getHomeV2PrincipalOuts_(showState) {
  return getHomeV2CastOuts_(showState).filter(function (item) {
    item = item || {};

    const out = String(item.out || item.Out || "").trim();
    const role = String(item.role || item.Role || "").toLowerCase();

    if (!out) return false;

    if (
      role.includes("swing") ||
      role.includes("understudy") ||
      role.includes("u/s") ||
      role.includes("standby")
    ) {
      return false;
    }

    return true;
  });
}

