function drawHomeV2UtilityRow_(
  sh,
  row,
  utility
) {
  utility =
    utility || {};

  const theme =
    getHomeV2Theme_();

  const done =
    workflowStatusIsDoneFast_(
      utility.id
    );

  const runValidation =
    SpreadsheetApp
      .newDataValidation()
      .requireValueInList(
        ["▶ Run"],
        true
      )
      .setAllowInvalid(false)
      .build();

  /*
