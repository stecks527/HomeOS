 * CHUNK 7 — TIMELINE ITEMS FROM NOTES
 * Version: 0.3.4
 *************************************************/

function getHomeV2TimelineEvents_(timeline, showState) {
  const raw = timeline && Array.isArray(timeline.displayEvents)
    ? timeline.displayEvents
    : timeline && Array.isArray(timeline.events)
      ? timeline.events
      : [];

  const events = raw.filter(function (event) {
    event = event || {};
    const title = String(event.title || "").toLowerCase().trim();

    if (title === "15 minutes") return false;
    if (title === "10 minutes") return false;
    if (title === "5 minutes") return false;
    if (title === "places") return false;

    return true;
  });

  getHomeV2ScheduleEventsFromNotes_(showState).forEach(function (event) {
    events.push(event);
  });

  return events.sort(function (a, b) {
    const aSort = getHomeV2TimelineSortValue_(a);
    const bSort = getHomeV2TimelineSortValue_(b);
    return aSort - bSort;
  });
}

function getHomeV2ScheduleEventsFromNotes_(showState) {
  const notes = normalizeHomeV2Notes_(showState && showState.notes);
  if (!notes) return [];

  const lines = notes
    .split(/\n+/)
    .map(function (line) {
      return String(line || "").replace(/^[-•]\s*/, "").trim();
    })
    .filter(Boolean);

  const events = [];

  lines.forEach(function (line) {
    const upper = line.toUpperCase();

    // Press stays in Notes for now unless we build location intelligence later.
    if (upper.includes("PRESS") || upper.includes("FILMING")) {
      return;
    }

    if (isHomeV2PTLine_(line)) {
      events.push(buildHomeV2NoteTimelineEvent_(line, "PT", "PT"));
      return;
    }

    if (isHomeV2RehearsalLine_(line)) {
      events.push(buildHomeV2NoteTimelineEvent_(line, "Rehearsal", getHomeV2RehearsalTimelineTitle_(line)));
      return;
    }
  });

  return events.filter(function (event) {
    return event && (event.timeText || event.title);
  });
}

function isHomeV2PTLine_(line) {
  const upper = String(line || "").toUpperCase();

  return (
    upper.includes("PT ") ||
    upper.startsWith("PT") ||
    upper.includes("PHYSICAL THERAPY")
  );
}

function isHomeV2RehearsalLine_(line) {
  const upper = String(line || "").toUpperCase();

  return (
    upper.includes("REHEARSAL") ||
    upper.includes("BRUSH-UP") ||
    upper.includes("BRUSH UP") ||
    upper.includes("PUT-IN") ||
    upper.includes("PUT IN") ||
    upper.includes("UNDERSTUDY")
  );
}

function getHomeV2RehearsalTimelineTitle_(line) {
  const upper = String(line || "").toUpperCase();

  if (upper.includes("BRUSH-UP") || upper.includes("BRUSH UP")) {
    return "Brush-Up";
  }

  if (upper.includes("PUT-IN") || upper.includes("PUT IN")) {
    return "Put-In";
  }

  if (upper.includes("UNDERSTUDY")) {
    return "Understudy Rehearsal";
  }

  return "Rehearsal";
}

function buildHomeV2NoteTimelineEvent_(line, category, title) {
  const timeInfo = extractHomeV2TimeRange_(line);
  const location = extractHomeV2Location_(line);
  const date = getHomeV2SelectedDate_();

  return {
    source: "Home Notes",
    category: category,
    title: title,
    appliesTo: location || "",
    timeText: timeInfo.startText || "",
    endTimeText: timeInfo.endText || "",
    time: timeInfo.startText && date
      ? buildHomeV2DateTimeFromText_(date, timeInfo.startText)
      : null,
    displayOnDashboard: true,
    originalText: line
  };
}

function getHomeV2SelectedDate_() {
  const ss = SpreadsheetApp.getActive();
  const inOut = ss.getSheetByName("IN/OUT");
  if (!inOut) return null;

  const value = inOut.getRange("A3").getValue();

  if (value instanceof Date && !isNaN(value.getTime())) {
    return value;
  }

  const display = inOut.getRange("A3").getDisplayValue();

  if (typeof parseInOutDate_ === "function") {
    return parseInOutDate_(display);
  }

  const parsed = new Date(display);
  return isNaN(parsed.getTime()) ? null : parsed;
}

function buildHomeV2DateTimeFromText_(date, timeText) {
  if (!(date instanceof Date)) return null;

  const text = String(timeText || "").trim().toUpperCase();
  const match = text.match(/(\d{1,2})(?::(\d{2}))?\s*(AM|PM)?/i);

  if (!match) return null;

  let hour = Number(match[1]);
  const minute = match[2] ? Number(match[2]) : 0;
  const ampm = String(match[3] || "").toUpperCase();

  if (ampm === "PM" && hour !== 12) hour += 12;
  if (ampm === "AM" && hour === 12) hour = 0;

  const result = new Date(date);
  result.setHours(hour, minute, 0, 0);

  return result;
}

function extractHomeV2TimeRange_(line) {
  const text = String(line || "");

  const rangeMatch = text.match(
    /(\d{1,2}(?::\d{2})?\s*(?:AM|PM)?)\s*[-–]\s*(\d{1,2}(?::\d{2})?\s*(?:AM|PM)?)/i
  );

  if (rangeMatch) {
    return {
      startText: normalizeHomeV2TimeText_(rangeMatch[1]),
      endText: normalizeHomeV2TimeText_(rangeMatch[2])
    };
  }

  const singleMatch = text.match(/(\d{1,2}(?::\d{2})?\s*(?:AM|PM))/i);

  if (singleMatch) {
    return {
      startText: normalizeHomeV2TimeText_(singleMatch[1]),
      endText: ""
    };
  }

  return {
    startText: "",
    endText: ""
  };
}

function normalizeHomeV2TimeText_(value) {
  let text = String(value || "").trim().toUpperCase().replace(/\s+/g, " ");

  const match = text.match(/^(\d{1,2})(AM|PM)$/i);
  if (match) {
    text = match[1] + ":00 " + match[2].toUpperCase();
  }

  const match2 = text.match(/^(\d{1,2})\s+(AM|PM)$/i);
  if (match2) {
    text = match2[1] + ":00 " + match2[2].toUpperCase();
  }

  return text;
}

function extractHomeV2Location_(line) {
  const text = String(line || "");

  const paren = text.match(/\(([^)]+)\)/);
  if (paren) return paren[1].trim();

  const atMatch = text.match(/\bat\s+(.+)$/i);
  if (atMatch) return atMatch[1].trim();

  return "";
}

function getHomeV2TimelineSortValue_(event) {
  if (event && event.time) {
    return new Date(event.time).getTime();
  }

  return homeV2TimeSortValue_(event && event.timeText);
}

