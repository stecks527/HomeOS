function normalizeHomeV2Text_(value) {
  return String(value || "")
    .replace(/\r/g, "")
    .replace(/\n{3,}/g, "\n\n")
    .trim();
}

function normalizeHomeV2Notes_(notes) {
  if (!notes) return "";

  if (Array.isArray(notes)) {
    return normalizeHomeV2Text_(notes.join("\n"));
  }

  return normalizeHomeV2Text_(notes);
}

function homeV2SafeArray_(value) {
  return Array.isArray(value) ? value : [];
}

/*************************************************
 * SHARED SHOWSTATE HELPERS
 *************************************************/

function getHomeV2Performances_(showState) {
  return homeV2SafeArray_(showState && showState.performances);
}

function getHomeV2CastOuts_(showState) {
  return homeV2SafeArray_(showState && showState.currentCastOuts);
}

function getHomeV2FirstPerformance_(showState) {
  const perfs = getHomeV2Performances_(showState);
  return perfs.length ? perfs[0] : {};
}

function getHomeConductorFromShowState_(showState) {
  const perfs = getHomeV2Performances_(showState);

  for (let i = 0; i < perfs.length; i++) {
    const conductor = perfs[i].conductor || "";
    if (conductor) return conductor;
  }

  return showState && showState.conductor ? showState.conductor : "";
}

function getHomeGuestSpellerFromShowState_(showState) {
  if (!showState) return "";

  const guestState = showState.guestSpeller;

  /*
   * The canonical ShowState object explicitly says
   * whether a guest exists.
   */
  if (
    guestState &&
    typeof guestState === "object" &&
    guestState.exists === false
  ) {
    return "";
  }

  const directName =
    homeV2ExtractDisplayName_(guestState);

  if (directName) {
    return directName;
  }

  const performances =
    getHomeV2Performances_(showState);

  for (let i = 0; i < performances.length; i++) {
    const performance = performances[i] || {};

    const guestName =
      homeV2ExtractDisplayName_(
        performance.guestSpeller
      );

    if (guestName) {
      return guestName;
    }
  }

  return "";
}

function homeV2ExtractDisplayName_(value) {
  if (
    value === null ||
    value === undefined ||
    value === false
  ) {
    return "";
  }

  if (typeof value === "string") {
    const clean = value.trim();

    if (
      !clean ||
      clean === "[object Object]" ||
      clean.toUpperCase() === "NONE" ||
      clean.toUpperCase() === "N/A" ||
      clean.toUpperCase() === "TBD"
    ) {
      return "";
    }

    return clean;
  }

  if (typeof value !== "object") {
    return "";
  }

  const possibleValues = [
    value.name,
    value.fullName,
    value.displayName,
    value.guestName,
    value.guestSpeller
  ];

  for (let i = 0; i < possibleValues.length; i++) {
    const result = homeV2ExtractDisplayName_(
      possibleValues[i]
    );

    if (result) return result;
  }

  return "";
}

function homeV2HasGuestSpeller_(showState) {
  return Boolean(
    getHomeGuestSpellerFromShowState_(
      showState || {}
    )
  );
}

function formatHomeV2PerformanceShort_(perf) {
  if (typeof perf === "string") return perf;

  perf = perf || {};

  const number = perf.number || perf.performanceNumber || "";
  const time = perf.time || perf.performanceTime || "";

  if (number && time) return "Performance #" + number + " • " + time;
  if (number) return "Performance #" + number;
  if (time) return time;

  return (
    perf.inOutText ||
    perf.performanceText ||
    perf.label ||
    perf.title ||
    "Performance"
  );
}

function formatHomeV2PerformanceTitle_(perf) {
  if (typeof perf === "string") return perf;

  perf = perf || {};

  const number = perf.number || perf.performanceNumber || "";
  return number ? "PERFORMANCE #" + number : "PERFORMANCE";
}

function formatHomeV2PerformanceTime_(perf) {
  if (typeof perf === "string") return "";

  perf = perf || {};
  return perf.time || perf.performanceTime || "";
}

