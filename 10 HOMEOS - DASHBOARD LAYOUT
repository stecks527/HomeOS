/* =========================================================
 * UTILITY ROW
 * ========================================================= */

function drawHomeV2UtilityRow_(
  sh,
  row,
  utility
) {
  utility =
    utility || {};

  const theme =
    getHomeV2Theme_();

  const done =
    workflowStatusIsDoneFast_(
      utility.id
    );

  const runValidation =
    SpreadsheetApp
      .newDataValidation()
      .requireValueInList(
        ["▶ Run"],
        true
      )
      .setAllowInvalid(false)
      .build();

  /*
   * DONE CHECKBOX
   */
  sh.getRange(
    row,
    1
  )
    .clearContent()
    .clearDataValidations()
    .insertCheckboxes()
    .setValue(
      done
    )
    .setNote(
      "WORKFLOW_TASK:" +
      utility.id
    )
    .setHorizontalAlignment(
      "center"
    )
    .setVerticalAlignment(
      "middle"
    )
    .setBackground(
      theme.cardColor
    );

  /*
   * UTILITY NAME
   */
  sh.getRange(
    row,
    2,
    1,
    7
  )
    .merge()
    .setValue(
      utility.title ||
      ""
    )
    .setFontSize(12)
    .setFontWeight(
      "bold"
    )
    .setFontColor(
      done
        ? "#888888"
        : "#111111"
    )
    .setFontLine(
      done
        ? "line-through"
        : "none"
    )
    .setHorizontalAlignment(
      "left"
    )
    .setVerticalAlignment(
      "middle"
    )
    .setBackground(
      theme.cardColor
    );

  /*
   * RUN DROPDOWN
   */
  sh.getRange(
    row,
    9
  )
    .clearContent()
    .clearDataValidations()
    .setDataValidation(
      runValidation
    )
    .setNote(
      "MISSION_ACTION:" +
      utility.action
    )
    .setFontSize(11)
    .setFontWeight(
      "bold"
    )
    .setFontColor(
      theme.primaryColor
    )
    .setHorizontalAlignment(
      "center"
    )
    .setVerticalAlignment(
      "middle"
    )
    .setBackground(
      "#F6F8FC"
    );

  sh.setRowHeight(
    row,
    40
  );

  return (
    row + 1
  );
}


/* =========================================================
 * UTILITY CARD BORDERS
 * ========================================================= */

function styleHomeV2UtilityCard_(
  sh,
  startRow,
  numRows
) {
  const theme =
    getHomeV2Theme_();

  const range =
    sh.getRange(
      startRow,
      HOME_V2.FULL_COL,
      numRows,
      HOME_V2.FULL_WIDTH
    );

  /*
   * Remove inherited internal gridlines.
   */
  range.setBorder(
    false,
    false,
    false,
    false,
    false,
    false
  );

  /*
   * Keep horizontal row dividers only.
   */
  range.setBorder(
    false,
    false,
    false,
    false,
    false,
    true,
    theme.borderColor,
    SpreadsheetApp.BorderStyle.SOLID
  );

  /*
   * Strong outside frame.
   */
  range.setBorder(
    true,
    true,
    true,
    true,
    null,
    null,
    theme.borderColor,
    SpreadsheetApp.BorderStyle.SOLID_MEDIUM
  );

  /*
   * Strong divider beneath blue title row.
   */
  sh.getRange(
    startRow,
    HOME_V2.FULL_COL,
    1,
    HOME_V2.FULL_WIDTH
  )
    .setBorder(
      null,
      null,
      true,
      null,
      false,
      false,
      theme.borderColor,
      SpreadsheetApp.BorderStyle.SOLID_MEDIUM
    );
}

