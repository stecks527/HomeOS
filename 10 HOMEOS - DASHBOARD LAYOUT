function drawHomeV2TaskList_(
  sh,
  row,
  col,
  width,
  tasks,
  showState
) {
  const startRow =
    row;

  const theme =
    getHomeV2Theme_();

  const taskList =
    Array.isArray(tasks)
      ? tasks
      : [];

  if (!taskList.length) {
    drawHomeV2EmptyLine_(
      sh,
      row,
      col,
      width,
      "No tasks found."
    );

    return 1;
  }

  const runValidation =
    SpreadsheetApp
      .newDataValidation()
      .requireValueInList(
        ["▶ Run"],
        true
      )
      .setAllowInvalid(false)
      .build();

  taskList.forEach(
    function (task) {
      task =
        task || {};

      const done =
        workflowStatusIsDoneFast_(
          task.id
        );

      const display =
        getHomeV2TaskDisplay_(
          task,
          showState
        );

      /*
       * DONE CHECKBOX
       */
      sh.getRange(
        row,
        col
      )
        .clearContent()
        .clearDataValidations()
        .insertCheckboxes()
        .setValue(done)
        .setNote(
          "WORKFLOW_TASK:" +
          task.id
        )
        .setHorizontalAlignment(
          "center"
        )
        .setVerticalAlignment(
          "middle"
        )
        .setBackground(
          theme.cardColor
        );

      /*
       * TASK TITLE + BULLET DETAILS
       */
      const titleRange =
        sh.getRange(
          row,
          col + 1,
          1,
          width - 2
        )
          .merge();

      titleRange
        .setRichTextValue(
          buildHomeV2TaskRichText_(
            display,
            done
          )
        )
        .setHorizontalAlignment(
          "left"
        )
        .setVerticalAlignment(
          "middle"
        )
        .setWrap(true)
        .setBackground(
          theme.cardColor
        );

      /*
       * RUN CONTROL
       */
      const actionCell =
        sh.getRange(
          row,
          col + width - 1
        );

      actionCell
        .clearContent()
        .clearDataValidations()
        .setDataValidation(
          runValidation
        )
        .setNote(
          task.action
            ? (
                "MISSION_ACTION:" +
                task.action
              )
            : ""
        )
        .setFontSize(11)
        .setFontWeight("bold")
        .setFontColor(
          task.action
            ? theme.primaryColor
            : theme.mutedText
        )
        .setHorizontalAlignment(
          "center"
        )
        .setVerticalAlignment(
          "middle"
        )
        .setBackground(
          "#F6F8FC"
        );

      if (!task.action) {
        actionCell
          .clearDataValidations()
          .setValue("—");
      }

      const detailCount =
        Array.isArray(
          display.details
        )
          ? display.details.length
          : 0;

      const rowHeight =
        detailCount
          ? (
              48 +
              detailCount * 17 +
              (
                display.footnote
                  ? 18
                  : 0
              )
            )
          : (
              String(
                display.title || ""
              ).length > 42
                ? 58
                : 40
            );

      sh.setRowHeight(
        row,
        rowHeight
      );

      row++;
    }
  );

  return (
    row -
    startRow
  );
}

function buildHomeV2TaskRichText_(
  display,
  done
) {
  display =
    display || {};

  const title =
    String(
      display.title || ""
    );

  const details =
    Array.isArray(
      display.details
    )
      ? display.details
          .map(function (item) {
            return String(
              item || ""
            ).trim();
          })
          .filter(Boolean)
      : [];

  const footnote =
    String(
      display.footnote || ""
    ).trim();

  const lines = [
    title
  ];

  if (details.length) {
    lines.push("");

    details.forEach(
      function (detail) {
        lines.push(
          "  • " +
          detail
        );
      }
    );
  }

  if (footnote) {
    lines.push("");
    lines.push(
      "  " +
      footnote
    );
  }

  const text =
    lines.join("\n");

  const builder =
    SpreadsheetApp
      .newRichTextValue()
      .setText(
        text
      );

  const theme =
    getHomeV2Theme_();

  const titleStyle =
    SpreadsheetApp
      .newTextStyle()
      .setFontFamily(
        HOME_V2.FONT
      )
      .setFontSize(12)
      .setBold(true)
      .setForegroundColor(
        done
          ? "#888888"
          : "#111111"
      )
      .setStrikethrough(
        done
      )
      .build();

  const detailStyle =
    SpreadsheetApp
      .newTextStyle()
      .setFontFamily(
        HOME_V2.FONT
      )
      .setFontSize(9)
      .setBold(false)
      .setForegroundColor(
        done
          ? "#999999"
          : "#555555"
      )
      .setStrikethrough(
        done
      )
      .build();

  const footnoteStyle =
    SpreadsheetApp
      .newTextStyle()
      .setFontFamily(
        HOME_V2.FONT
      )
      .setFontSize(8)
      .setItalic(true)
      .setForegroundColor(
        done
          ? "#A0A0A0"
          : theme.mutedText
      )
      .setStrikethrough(
        done
      )
      .build();

  if (title) {
    builder.setTextStyle(
      0,
      title.length,
      titleStyle
    );
  }

  details.forEach(
    function (detail) {
      const bulletText =
        "  • " +
        detail;

      const start =
        text.indexOf(
          bulletText
        );

      if (start >= 0) {
        builder.setTextStyle(
          start,
          start +
            bulletText.length,
          detailStyle
        );
      }
    }
  );

  if (footnote) {
    const footnoteText =
      "  " +
      footnote;

    const start =
      text.lastIndexOf(
        footnoteText
      );

    if (start >= 0) {
      builder.setTextStyle(
        start,
        start +
          footnoteText.length,
        footnoteStyle
      );
    }
  }

  return builder.build();
}

