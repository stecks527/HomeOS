 * ========================================================= */

function drawHomeV2TodayCompany_(
  sh,
  row,
  showState
) {
  const lines =
    buildHomeV2TodayCompanyObjects_(
      showState
    );

  if (!lines.length) {
    return row;
  }

  const startRow =
    row;

  row =
    drawHomeV2CardTitle_(
      sh,
      row,
      HOME_V2.FULL_COL,
      HOME_V2.FULL_WIDTH,
      "TODAY'S COMPANY"
    );

  lines.forEach(
    function (item) {
      /*
       * OUT ACTOR
       */
      sh.getRange(
        row,
        1,
        1,
        3
      )
        .merge()
        .setValue(
          item.outActor
        )
        .setFontSize(14)
        .setFontWeight("bold")
        .setHorizontalAlignment("left")
        .setVerticalAlignment("middle");

      /*
       * OUT LABEL
       */
      sh.getRange(
        row,
        4
      )
        .setValue("OUT")
        .setFontSize(12)
        .setFontWeight("bold")
        .setFontColor("#B00020")
        .setHorizontalAlignment("center")
        .setVerticalAlignment("middle");

      /*
       * ROLE / COVERAGE
       */
      sh.getRange(
        row,
        5,
        1,
        4
      )
        .merge()
        .setValue(
          item.inActor
            ? (
                item.role +
                " = " +
                item.inActor
              )
            : item.role
        )
        .setFontSize(13)
        .setFontWeight("bold")
        .setHorizontalAlignment("left")
        .setVerticalAlignment("middle")
        .setWrap(true);

      /*
       * CLASSIFICATION
       */
      sh.getRange(
        row,
        9
      )
        .setValue(
          item.classification ||
          ""
        )
        .setFontSize(10)
        .setFontWeight("bold")
        .setFontColor(
          getHomeV2OutClassificationColor_(
            item.classification
          )
        )
        .setHorizontalAlignment("center")
        .setVerticalAlignment("middle")
        .setWrap(true);

      sh.setRowHeight(
        row,
        44
      );

      row++;
    }
  );

  fillHomeV2CardBody_(
    sh,
    startRow + 1,
    HOME_V2.FULL_COL,
    row - startRow - 1,
    HOME_V2.FULL_WIDTH
  );

  styleHomeV2Card_(
    sh,
    startRow,
    HOME_V2.FULL_COL,
    row - startRow,
    HOME_V2.FULL_WIDTH
  );

  return (
    row +
    HOME_V2.GAP_ROWS
  );
}


function buildHomeV2TodayCompanyLines_(
  showState
) {
  return buildHomeV2TodayCompanyObjects_(
    showState
  ).map(
    function (item) {
      const main =
        item.outActor +
        " OUT, " +
        item.role +
        (
          item.inActor
            ? " = " + item.inActor
            : ""
        );

      return item.classification
        ? main +
          " — " +
          item.classification
        : main;
    }
  );
}


function buildHomeV2TodayCompanyObjects_(
  showState
) {
  const liveRows =
    buildHomeV2TodayCompanyObjectsFromInOut_();

  if (liveRows.length) {
    return liveRows;
  }

  return getHomeV2CastOuts_(
    showState
  )
    .map(
      function (item) {
        item =
          item || {};

        const rawOutActor =
          normalizeHomeV2Text_(
            item.out ||
            item.Out ||
            item.actorOut ||
            item.actor ||
            ""
          );

        const rawRole =
          normalizeHomeV2Text_(
            item.role ||
            item.Role ||
            item.character ||
            ""
          );

        const rawInActor =
          normalizeHomeV2Text_(
            item.in ||
            item.In ||
            item.actorIn ||
            item.coverActor ||
            item.cover ||
            ""
          );

        const reason =
          normalizeHomeV2Text_(
            item.reason ||
            item.Reason ||
            item.outType ||
            item.approvalStatus ||
            ""
          );

        if (!rawOutActor) {
          return null;
        }

        return buildHomeV2TodayCompanyObject_(
          rawOutActor,
          rawInActor,
          rawRole,
          reason,
          null
        );
      }
    )
    .filter(Boolean);
}


function buildHomeV2TodayCompanyObjectsFromInOut_() {
  const ss =
    SpreadsheetApp.getActive();

  const sh =
    ss.getSheetByName(
      "IN/OUT"
    );

  if (!sh) {
    return [];
  }

  const values =
    sh
      .getRange("A6:G23")
      .getDisplayValues();

  const output = [];

  const stopLabels = [
    "CALLING SM",
    "DECK SM",
    "CONDUCTOR",
    "A1",
    "A1 / MIXER",
    "PRODUCTION SOUND"
  ];

  for (
    let index = 0;
    index < values.length;
    index++
  ) {
    const sourceRow =
      index + 6;

    const row =
      values[index];

    const colA =
      normalizeHomeV2Text_(
        row[0]
      );

    const colC =
      normalizeHomeV2Text_(
        row[2]
      );

    const colD =
      normalizeHomeV2Text_(
        row[3]
      );

    const colE =
      normalizeHomeV2Text_(
        row[4]
      );

    const colF =
      normalizeHomeV2Text_(
        row[5]
      );

    const colG =
      normalizeHomeV2Text_(
        row[6]
      );

    const rowLabels = [
      colA,
      colC,
      colD,
      colE,
      colF,
      colG
    ].map(
      function (value) {
        return String(
          value || ""
        )
          .toUpperCase()
          .trim();
      }
    );

    const reachedAssignments =
      rowLabels.some(
        function (value) {
          return (
            stopLabels.indexOf(
              value
            ) !== -1
          );
        }
      );

    if (reachedAssignments) {
      break;
    }

    if (!colA) {
      continue;
    }

    output.push(
      buildHomeV2TodayCompanyObject_(
        colA,
        colC,
        colE || colD || colF,
        colG,
        sourceRow
      )
    );
  }

  return output.filter(Boolean);
}


/* =========================================================
 * COMPANY ROW NORMALIZATION
 * ========================================================= */

function buildHomeV2TodayCompanyObject_(
  rawOutActor,
  rawInActor,
  rawRole,
  reason,
  sourceRow
) {
  const outActor =
    expandHomeV2PersonName_(
      rawOutActor
    );

  const noCoverNeeded =
    homeV2IsNonCompanyOut_(
      rawRole,
      reason
    );

  const contactDescriptor =
    noCoverNeeded
      ? getHomeV2ContactDescriptor_(
          outActor
        )
      : "";

  const role =
    contactDescriptor ||
    expandHomeV2CharacterName_(
      rawRole,
      outActor
    ) ||
    rawRole ||
    "Pending Assignment";

  const inActor =
    noCoverNeeded
      ? ""
      : (
          expandHomeV2PersonName_(
            rawInActor
          ) ||
          "TBD"
        );

  return {
    sourceRow:
      sourceRow || null,

    outActor:
      outActor ||
      rawOutActor,

    role:
      role,

    inActor:
      inActor,

    reason:
      reason || "",

    classification:
      classifyHomeV2CompanyOut_(
        reason
      ),

    noCoverNeeded:
      noCoverNeeded
  };
}


/* =========================================================
 * FULL PERSON NAMES
 * ========================================================= */

function expandHomeV2PersonName_(
  value
) {
  const input =
    normalizeHomeV2Text_(
      value
    );

  if (!input) {
    return "";
  }

  const castData =
    typeof getCastListData_ ===
      "function"
      ? getCastListData_()
      : null;

  const rows =
    castData &&
    Array.isArray(
      castData.rows
    )
      ? castData.rows
      : [];

  const wanted =
    normalizeHomeV2LookupText_(
      input
    );

  for (
    let index = 0;
    index < rows.length;
    index++
  ) {
    const row =
      rows[index] || {};

    const fullName =
      normalizeHomeV2Text_(
        row.fullName
      );

    const firstInitial =
      normalizeHomeV2Text_(
        row.firstInitial
      );

    if (
      normalizeHomeV2LookupText_(
        fullName
      ) === wanted ||
      normalizeHomeV2LookupText_(
        firstInitial
      ) === wanted
    ) {
      return (
        fullName ||
        input
      );
    }
  }

  /*
   * Contact Sheet fallback for crew and Stage Management.
   */
  const contactName =
    findHomeV2FullNameFromContactSheet_(
      input
    );

  return (
    contactName ||
    input
  );
}


function findHomeV2FullNameFromContactSheet_(
  value
) {
  const wanted =
    normalizeHomeV2LookupText_(
      value
    );

  if (!wanted) {
    return "";
  }

  const ss =
    SpreadsheetApp.getActive();

  const sh =
    ss.getSheetByName(
      "Contact Sheet"
    );

  if (
    !sh ||
    sh.getLastRow() < 1
  ) {
    return "";
  }

  const values =
    sh
      .getRange(
        1,
        1,
        sh.getLastRow(),
        Math.min(
          sh.getLastColumn(),
          6
        )
      )
      .getDisplayValues();

  for (
    let rowIndex = 0;
    rowIndex < values.length;
    rowIndex++
  ) {
    const row =
      values[rowIndex];

    const possibleNames = [
      row[0] || "",
      row[1] || ""
    ];

    const matched =
      possibleNames.some(
        function (name) {
          return (
            normalizeHomeV2LookupText_(
              name
            ) === wanted
          );
        }
      );

    if (matched) {
      return normalizeHomeV2Text_(
        row[0] ||
        row[1] ||
        value
      );
    }
  }

  return "";
}


/* =========================================================
 * FULL CHARACTER NAMES
 * ========================================================= */

function expandHomeV2CharacterName_(
  roleValue,
  outActor
) {
  const role =
    normalizeHomeV2Text_(
      roleValue
    );

  const castData =
    typeof getCastListData_ ===
      "function"
      ? getCastListData_()
      : null;

  const rows =
    castData &&
    Array.isArray(
      castData.rows
    )
      ? castData.rows
      : [];

  const actorKey =
    normalizeHomeV2LookupText_(
      outActor
    );

  /*
   * The actor's principal character is the safest match.
   */
  if (actorKey) {
    for (
      let index = 0;
      index < rows.length;
      index++
    ) {
      const row =
        rows[index] || {};

      if (
        normalizeHomeV2LookupText_(
          row.fullName
        ) === actorKey &&
        row.character
      ) {
        return normalizeHomeV2Text_(
          row.character
        );
      }
    }
  }

  const roleKey =
    normalizeHomeV2LookupText_(
      role
    );

  if (!roleKey) {
    return "";
  }

  for (
    let index = 0;
    index < rows.length;
    index++
  ) {
    const row =
      rows[index] || {};

    const fullCharacter =
      normalizeHomeV2Text_(
        row.character
      );

    const shortRole =
      normalizeHomeV2Text_(
        row.role
      );

    const characterKey =
      normalizeHomeV2LookupText_(
        fullCharacter
      );

    const shortRoleKey =
      normalizeHomeV2LookupText_(
        shortRole
      );

    if (
      roleKey === characterKey ||
      roleKey === shortRoleKey ||
      (
        characterKey &&
        characterKey.includes(
          roleKey
        )
      )
    ) {
      return (
        fullCharacter ||
        role
      );
    }
  }

  return role;
}


/* =========================================================
 * OUT CLASSIFICATION
 * ========================================================= */

function classifyHomeV2CompanyOut_(
  reason
) {
  const text =
    String(
      reason || ""
    )
      .toUpperCase()
      .replace(/\s+/g, " ")
      .trim();

  if (!text) {
    return "";
  }

  if (
    text.includes("CALL-IN") ||
    text.includes("CALL IN") ||
    text.includes("CALLED IN") ||
    text.includes("SICK") ||
    text.includes("ILLNESS")
  ) {
    return "CALL-IN";
  }

  if (
    text === "PD" ||
    text.includes("PERSONAL DAY") ||
    (
      text.includes("APPROVED") &&
      text.includes("PD")
    )
  ) {
    return "APPROVED PD";
  }

  if (
    text.includes("VACATION")
  ) {
    return "VACATION";
  }

  if (
    text.includes("MLOA")
  ) {
    return "MLOA";
  }

  if (
    text.includes("LOA")
  ) {
    return "LOA";
  }

  return text;
}


function getHomeV2OutClassificationColor_(
  classification
) {
  const text =
    String(
      classification || ""
    ).toUpperCase();

  if (
    text === "CALL-IN"
  ) {
    return "#B00020";
  }

  if (
    text === "APPROVED PD" ||
    text === "VACATION"
  ) {
    return getHomeV2Theme_()
      .primaryColor;
  }

  return "#555555";
}


/* =========================================================
 * LOOKUP NORMALIZATION
 * ========================================================= */

function normalizeHomeV2LookupText_(
  value
) {
  return String(
    value || ""
  )
    .toUpperCase()
    .replace(/[^A-Z0-9]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}


function homeV2IsNonCompanyOut_(
  role,
  reason
) {
  const text =
    String(
      role +
      " " +
      reason
    ).toLowerCase();

  return (
    text.includes("swing") ||
    text.includes("understudy") ||
    text.includes("u/s") ||
    text.includes("standby")
  );
}


function getHomeV2ContactDescriptor_(
  personName
) {
  const cleanName =
    normalizeHomeV2Text_(
      personName
    );

  if (!cleanName) {
    return "";
  }

  const ss =
    SpreadsheetApp.getActive();

  const contactSheet =
    ss.getSheetByName(
      "Contact Sheet"
    );

  if (
    !contactSheet ||
    contactSheet.getLastRow() < 1
  ) {
    return "";
  }

  const values =
    contactSheet
      .getRange(
        1,
        1,
        contactSheet.getLastRow(),
        6
      )
      .getDisplayValues();

  const wantedName =
    normalizeHomeV2LookupText_(
      cleanName
    );

  for (
    let index = 0;
    index < values.length;
    index++
  ) {
    const row =
      values[index];

    const rowContainsPerson =
      row.some(
        function (value) {
          return (
            normalizeHomeV2LookupText_(
              value
            ) === wantedName
          );
        }
      );

    if (!rowContainsPerson) {
      continue;
    }

    const descriptor =
      normalizeHomeV2Text_(
        row[2]
      );

    if (descriptor) {
      return descriptor;
    }
  }

  return "";
}


