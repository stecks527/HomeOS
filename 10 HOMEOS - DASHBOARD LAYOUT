let HOME_V2_THEME_CACHE_ = null;

function getHomeV2Theme_() {
  if (HOME_V2_THEME_CACHE_) return HOME_V2_THEME_CACHE_;

  HOME_V2_THEME_CACHE_ = {
    productionName: getHomeV2Setting_("Production Name", HOME_V2.DEFAULT_PRODUCTION_NAME),
    primaryColor: getHomeV2Setting_("Primary Color", HOME_V2.DEFAULT_PRIMARY),
    secondaryColor: getHomeV2Setting_("Secondary Color", HOME_V2.DEFAULT_SECONDARY),
    darkColor: getHomeV2Setting_("Dark Color", HOME_V2.DEFAULT_DARK),
    backgroundColor: HOME_V2.DEFAULT_BG,
    cardColor: HOME_V2.DEFAULT_CARD,
    borderColor: HOME_V2.DEFAULT_BORDER,
    mutedText: HOME_V2.DEFAULT_MUTED,
    pastBackground: HOME_V2.DEFAULT_PAST_BG,
    noteBackground: HOME_V2.DEFAULT_NOTE_BG
  };

  return HOME_V2_THEME_CACHE_;
}

function getHomeV2Setting_(label, fallback) {
  const ss = SpreadsheetApp.getActive();
  const sh = ss.getSheetByName("Production Settings");

  if (!sh) return fallback;

  const lastRow = sh.getLastRow();
  if (lastRow < 1) return fallback;

  const values = sh.getRange(1, 1, lastRow, 2).getDisplayValues();

  for (let i = 0; i < values.length; i++) {
    if (String(values[i][0] || "").trim() === label) {
      return String(values[i][1] || "").trim() || fallback;
    }
  }

  return fallback;
}

function getHomeV2HeroColor_() {
  return getHomeV2Setting_(
    "Home Hero Color",
    "#173B8F"
  );
}

