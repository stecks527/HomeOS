let HOME_CURRENT_CONTEXT_ = null;
let HOME_TASK_CONTEXT_CACHE_ = null;

function getHomeTaskContext_() {
  if (HOME_TASK_CONTEXT_CACHE_) return HOME_TASK_CONTEXT_CACHE_;

  const ctx =
    HOME_CURRENT_CONTEXT_ ||
    buildHomeContext_();

  const showState = ctx.showState || {};

  HOME_TASK_CONTEXT_CACHE_ = {
    showState,
    snapshotId: buildHomeSnapshotIdFromShowState_(showState),
    hasGuestSpeller: homeV2HasGuestSpeller_(showState),
    insertLineCount: getHomeV2PrincipalOuts_(showState).length
  };

  return HOME_TASK_CONTEXT_CACHE_;
}

function clearHomeTaskContextCache_() {
  HOME_TASK_CONTEXT_CACHE_ = null;
}

function buildHomeSnapshotIdFromShowState_(showState) {
  showState = showState || {};

  const perf = (showState.performances || [])[0] || {};
  const perfNumber = perf.number || perf.performanceNumber || "NO_PERF";
  const dateText = showState.prettyDate || showState.date || "NO_DATE";

  return String(dateText + "|" + perfNumber)
    .toUpperCase()
    .replace(/[^A-Z0-9]+/g, "_");
}

