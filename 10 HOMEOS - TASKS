let HOME_WORKFLOW_STATUS_CACHE_ = null;

function workflowStatusIsDoneFast_(taskId) {
  const ctx = getHomeTaskContext_();
  const snapshotId = ctx.snapshotId || "NO_SNAPSHOT";

  if (!HOME_WORKFLOW_STATUS_CACHE_) {
    HOME_WORKFLOW_STATUS_CACHE_ =
      PropertiesService.getDocumentProperties().getProperties();
  }

  const key = [
    "WORKFLOW",
    snapshotId,
    String(taskId || "").toUpperCase().replace(/\s+/g, "_")
  ].join("|");

  return HOME_WORKFLOW_STATUS_CACHE_[key] === "TRUE";
}
