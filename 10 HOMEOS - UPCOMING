/* =========================================================
 * HOME V2 ENTRY POINT
 * ========================================================= */

function drawHomeV2UpcomingCard_(sh, row) {
  const startRow = row;
  const theme = getHomeUpcomingTheme_();

  /*
   * Main UPCOMING title.
   */
  sh.getRange(row, 1, 1, 9)
    .merge()
    .setValue("UPCOMING")
    .setFontFamily("Arial")
    .setFontSize(12)
    .setFontWeight("bold")
    .setFontColor("#FFFFFF")
    .setHorizontalAlignment("center")
    .setVerticalAlignment("middle")
    .setBackground(theme.darkBlue)
    .setBorder(
      true,
      true,
      true,
      true,
      false,
      false,
      theme.darkBlue,
      SpreadsheetApp.BorderStyle.SOLID_MEDIUM
    );

  sh.setRowHeight(row, 30);
  row++;

  /*
   * One shared column-heading row.
   */
  row = drawHomeUpcomingColumnHeaders_(sh, row, theme);

  const upcoming = getDashboardUpcomingFromWeekly_();

  if (!upcoming.length) {
    sh.getRange(row, 1, 1, 9)
      .merge()
      .setValue("No upcoming schedule information found.")
      .setFontFamily("Arial")
      .setFontSize(10)
      .setFontColor(theme.mutedText)
      .setHorizontalAlignment("center")
      .setVerticalAlignment("middle")
      .setBackground("#FFFFFF")
      .setBorder(
        true,
        true,
        true,
        true,
        false,
        false,
        theme.borderColor,
        SpreadsheetApp.BorderStyle.SOLID
      );

    sh.setRowHeight(row, 36);
    row++;
  } else {
    upcoming.forEach(function(day) {
      row = drawHomeUpcomingDay_(sh, row, day, theme);
    });
  }

  /*
   * Outside border around the complete Upcoming section.
   */
  sh.getRange(
    startRow,
    1,
    Math.max(1, row - startRow),
    9
  ).setBorder(
    true,
    true,
    true,
    true,
    false,
    false,
    theme.darkBlue,
    SpreadsheetApp.BorderStyle.SOLID_MEDIUM
  );

  return row + 1;
}


/*
 * Compatibility alias.
 */
function drawUpcomingCard_(sh, row) {
  return drawHomeV2UpcomingCard_(sh, row);
}


/* =========================================================
 * COLUMN HEADERS
 * ========================================================= */

function drawHomeUpcomingColumnHeaders_(sh, row, theme) {
  sh.getRange(row, 1, 1, 2)
    .merge()
    .setValue("TIME");

  sh.getRange(row, 3, 1, 4)
    .merge()
    .setValue("EVENT");

  sh.getRange(row, 7, 1, 3)
    .merge()
    .setValue("WHO");

  sh.getRange(row, 1, 1, 9)
    .setFontFamily("Arial")
    .setFontSize(9)
    .setFontWeight("bold")
    .setFontColor("#111111")
    .setHorizontalAlignment("center")
    .setVerticalAlignment("middle")
    .setBackground(theme.headerFill)
    .setBorder(
      true,
      true,
      true,
      true,
      true,
      true,
      theme.borderColor,
      SpreadsheetApp.BorderStyle.SOLID
    );

  sh.setRowHeight(row, 22);

  return row + 1;
}


/* =========================================================
 * ONE DAY
 * ========================================================= */

function drawHomeUpcomingDay_(sh, row, day, theme) {
  day = day || {};

  row = drawHomeUpcomingDayHeader_(sh, row, day, theme);

  if (day.dayOff) {
    row = drawHomeUpcomingDayOff_(sh, row, day.dayOff, theme);
    return row + 1;
  }

  const events = Array.isArray(day.events)
    ? day.events
    : [];

  if (!events.length) {
    sh.getRange(row, 1, 1, 9)
      .merge()
      .setValue("No scheduled activity.")
      .setFontFamily("Arial")
      .setFontSize(10)
      .setFontColor(theme.mutedText)
      .setHorizontalAlignment("center")
      .setVerticalAlignment("middle")
      .setBackground("#FFFFFF")
      .setBorder(
        true,
        true,
        true,
        true,
        false,
        false,
        theme.borderColor,
        SpreadsheetApp.BorderStyle.SOLID
      );

    sh.setRowHeight(row, 30);
    row++;
  } else {
    let performanceDividerAdded = false;

    events.forEach(function(event) {
      const isPerformance =
        String(event.type || "").toLowerCase() === "performance";

      if (isPerformance && !performanceDividerAdded) {
        row = drawHomeUpcomingGoldDivider_(sh, row, theme);
        performanceDividerAdded = true;
      }

      row = drawHomeUpcomingEventRow_(sh, row, event, theme);
    });
  }

  if (
    Array.isArray(day.castChanges) &&
    day.castChanges.length
  ) {
    row = drawHomeUpcomingCastCrew_(sh, row, day.castChanges, theme);
  }

  if (
    day.ptSummary &&
    day.ptSummary.exists
  ) {
    row = drawHomeUpcomingPt_(sh, row, day.ptSummary, theme);
  }

  if (
    Array.isArray(day.notes) &&
    day.notes.length
  ) {
    row = drawHomeUpcomingNotes_(sh, row, day.notes, theme);
  }

  return row + 1;
}


/* =========================================================
 * DAY HEADER
 * ========================================================= */

function drawHomeUpcomingDayHeader_(sh, row, day, theme) {
  const title = buildHomeUpcomingDayHeaderText_(day);

  sh.getRange(row, 1, 1, 9)
    .merge()
    .setValue(title)
    .setFontFamily("Arial")
    .setFontSize(10)
    .setFontWeight("bold")
    .setFontColor(theme.gold)
    .setHorizontalAlignment("left")
    .setVerticalAlignment("middle")
    .setBackground(theme.weeklyBlue)
    .setBorder(
      true,
      true,
      true,
      true,
      false,
      false,
      "#111111",
      SpreadsheetApp.BorderStyle.SOLID_MEDIUM
    );

  sh.setRowHeight(row, 24);

  return row + 1;
}


function buildHomeUpcomingDayHeaderText_(day) {
  day = day || {};

  const dateLabel =
    day.dateLabel ||
    day.dayName ||
    "";

  if (day.dayOff) {
    return [
      dateLabel,
      day.dayOff.title || "DAY OFF"
    ]
      .filter(Boolean)
      .join("        ");
  }

  const summaries = [];

  const events = Array.isArray(day.events)
    ? day.events
    : [];

  events.forEach(function(event) {
    const type = String(event.type || "").toLowerCase();

    if (type === "rehearsal") {
      summaries.push(
        [
          cleanHomeUpcomingEventTitle_(event.title),
          buildHomeUpcomingTimeText_(
            event.startTime,
            event.endTime
          )
        ]
          .filter(Boolean)
          .join(" ")
      );
    }

    if (type === "performance") {
      summaries.push(
        [
          event.title || "Performance",
          normalizeHomeUpcomingTime_(event.startTime)
        ]
          .filter(Boolean)
          .join(" - ")
      );
    }
  });

  return [
    dateLabel,
    summaries.join(" + ")
  ]
    .filter(Boolean)
    .join("        ");
}


/* =========================================================
 * DAY OFF
 * ========================================================= */

function drawHomeUpcomingDayOff_(sh, row, dayOff, theme) {
  sh.getRange(row, 1, 1, 9)
    .merge()
    .setValue(dayOff.title || "AEA DAY OFF")
    .setFontFamily("Arial")
    .setFontSize(11)
    .setFontWeight("bold")
    .setFontColor(theme.mutedText)
    .setHorizontalAlignment("center")
    .setVerticalAlignment("middle")
    .setBackground("#FFFFFF")
    .setBorder(
      true,
      true,
      true,
      true,
      false,
      false,
      theme.borderColor,
      SpreadsheetApp.BorderStyle.SOLID
    );

  sh.setRowHeight(row, 34);

  return row + 1;
}


/* =========================================================
 * EVENT ROW
 * ========================================================= */

function drawHomeUpcomingEventRow_(sh, row, event, theme) {
  event = event || {};

  const type =
    String(event.type || "")
      .toLowerCase();

  const timeText =
    buildHomeUpcomingTimeText_(
      event.startTime,
      event.endTime
    );

  const eventTitle =
    cleanHomeUpcomingEventTitle_(
      event.title
    );

  const whoText =
    buildHomeUpcomingWhoText_(
      event,
      type
    );

  const eventDetails =
    buildHomeUpcomingEventDetails_(
      event,
      type
    );

  /*
   * TIME — columns A:B
   */
  sh.getRange(row, 1, 1, 2)
    .merge()
    .setValue(timeText)
    .setFontFamily("Arial")
    .setFontSize(10)
    .setFontWeight("bold")
    .setFontColor(
      type === "rehearsal"
        ? theme.linkBlue
        : "#111111"
    )
    .setHorizontalAlignment("center")
    .setVerticalAlignment("middle")
    .setWrap(true)
    .setBackground("#FFFFFF");

  /*
   * EVENT — columns C:F
   */
  const eventCell =
    sh.getRange(row, 3, 1, 4)
      .merge()
      .setValue(
        eventDetails
          ? eventTitle + "\n" + eventDetails
          : eventTitle
      )
      .setFontFamily("Arial")
      .setFontSize(10)
      .setFontColor(
        type === "rehearsal"
          ? theme.linkBlue
          : "#111111"
      )
      .setHorizontalAlignment("left")
      .setVerticalAlignment("middle")
      .setWrap(true)
      .setBackground("#FFFFFF");

  if (type === "performance") {
    eventCell.setFontWeight("bold");
  }

  /*
   * WHO — columns G:I
   */
  sh.getRange(row, 7, 1, 3)
    .merge()
    .setValue(whoText)
    .setFontFamily("Arial")
    .setFontSize(10)
    .setFontColor(
      type === "rehearsal"
        ? theme.linkBlue
        : "#111111"
    )
    .setHorizontalAlignment("left")
    .setVerticalAlignment("middle")
    .setWrap(true)
    .setBackground("#FFFFFF");

  sh.getRange(row, 1, 1, 9)
    .setBorder(
      true,
      true,
      true,
      true,
      true,
      true,
      theme.borderColor,
      SpreadsheetApp.BorderStyle.SOLID
    );

  const height =
    eventDetails ||
    whoText.length > 45
      ? 46
      : 30;

  sh.setRowHeight(row, height);

  return row + 1;
}


/* =========================================================
 * GOLD PERFORMANCE DIVIDER
 * ========================================================= */

function drawHomeUpcomingGoldDivider_(sh, row, theme) {
  sh.getRange(row, 1, 1, 9)
    .merge()
    .setValue("")
    .setBackground(theme.gold)
    .setBorder(
      true,
      true,
      true,
      true,
      false,
      false,
      "#111111",
      SpreadsheetApp.BorderStyle.SOLID
    );

  sh.setRowHeight(row, 5);

  return row + 1;
}


/* =========================================================
 * CAST / CREW
 * ========================================================= */

function drawHomeUpcomingCastCrew_(sh, row, castChanges, theme) {
  const lines = buildHomeUpcomingCastCrewLines_(castChanges);

  if (!lines.length) {
    return row;
  }

  sh.getRange(row, 1, 1, 2)
    .merge()
    .setValue("NOTES:")
    .setFontFamily("Arial")
    .setFontSize(10)
    .setFontWeight("bold")
    .setHorizontalAlignment("left")
    .setVerticalAlignment("top")
    .setBackground("#FFFFFF");

  sh.getRange(row, 3, 1, 7)
    .merge()
    .setValue(lines.join("\n"))
    .setFontFamily("Arial")
    .setFontSize(10)
    .setHorizontalAlignment("left")
    .setVerticalAlignment("top")
    .setWrap(true)
    .setBackground("#FFFFFF");

  sh.getRange(row, 1, 1, 9)
    .setBorder(
      true,
      true,
      true,
      true,
      true,
      true,
      theme.borderColor,
      SpreadsheetApp.BorderStyle.SOLID
    );

  sh.setRowHeight(
    row,
    Math.min(
      110,
      22 + lines.length * 15
    )
  );

  return row + 1;
}


function buildHomeUpcomingCastCrewLines_(values) {
  return (Array.isArray(values) ? values : [])
    .map(function(value) {
      let text = String(value || "").trim();

      if (!text) {
        return "";
      }

      /*
       * Keep the Weekly Schedule's simple note language.
       */
      if (text.charAt(0) !== "-") {
        text = "- " + text;
      }

      return text;
    })
    .filter(Boolean);
}


/* =========================================================
 * PT
 * ========================================================= */

function drawHomeUpcomingPt_(sh, row, ptSummary, theme) {
  const slots =
    Array.isArray(ptSummary.slots)
      ? ptSummary.slots
      : [];

  const detailLines = slots.map(function(slot) {
    const appointment =
      String(slot.appointment || "").trim();

    return [
      slot.timeText || "",
      appointment || "OPEN"
    ]
      .filter(Boolean)
      .join(" — ");
  });

  const summaryLine =
    ptSummary.filledCount +
    " of " +
    ptSummary.totalSlots +
    " slots filled";

  sh.getRange(row, 1, 1, 2)
    .merge()
    .setValue("PT:")
    .setFontFamily("Arial")
    .setFontSize(10)
    .setFontWeight("bold")
    .setFontColor(theme.linkBlue)
    .setHorizontalAlignment("left")
    .setVerticalAlignment("top")
    .setBackground("#FFFFFF");

  sh.getRange(row, 3, 1, 7)
    .merge()
    .setValue(
      detailLines
        .concat([summaryLine])
        .join("\n")
    )
    .setFontFamily("Arial")
    .setFontSize(10)
    .setFontColor(theme.linkBlue)
    .setHorizontalAlignment("left")
    .setVerticalAlignment("top")
    .setWrap(true)
    .setBackground("#FFFFFF");

  sh.getRange(row, 1, 1, 9)
    .setBorder(
      true,
      true,
      true,
      true,
      true,
      true,
      theme.borderColor,
      SpreadsheetApp.BorderStyle.SOLID
    );

  sh.setRowHeight(
    row,
    Math.min(
      120,
      26 + detailLines.length * 15
    )
  );

  return row + 1;
}


/* =========================================================
 * GENERAL NOTES
 * ========================================================= */

function drawHomeUpcomingNotes_(sh, row, notes, theme) {
  const lines = uniqueHomeUpcomingStrings_(notes)
    .map(function(note) {
      const text = String(note || "").trim();

      if (!text) {
        return "";
      }

      return text.charAt(0) === "-"
        ? text
        : "- " + text;
    })
    .filter(Boolean);

  if (!lines.length) {
    return row;
  }

  sh.getRange(row, 1, 1, 2)
    .merge()
    .setValue("NOTES:")
    .setFontFamily("Arial")
    .setFontSize(10)
    .setFontWeight("bold")
    .setHorizontalAlignment("left")
    .setVerticalAlignment("top")
    .setBackground("#FFFFFF");

  sh.getRange(row, 3, 1, 7)
    .merge()
    .setValue(lines.join("\n"))
    .setFontFamily("Arial")
    .setFontSize(10)
    .setHorizontalAlignment("left")
    .setVerticalAlignment("top")
    .setWrap(true)
    .setBackground("#FFFFFF");

  sh.getRange(row, 1, 1, 9)
    .setBorder(
      true,
      true,
      true,
      true,
      true,
      true,
      theme.borderColor,
      SpreadsheetApp.BorderStyle.SOLID
    );

  sh.setRowHeight(
    row,
    Math.min(
      120,
      22 + lines.length * 15
    )
  );

  return row + 1;
}


/* =========================================================
 * DISPLAY HELPERS
 * ========================================================= */

function cleanHomeUpcomingEventTitle_(value) {
  let text =
    String(value || "")
      .replace(/\s+/g, " ")
      .trim();

  if (!text) {
    return "";
  }

  if (/UNDERSTUDY\s+REH/i.test(text)) {
    return "Understudy Rehearsal";
  }

  if (/ONSTAGE\s+REH/i.test(text)) {
    return "Onstage Rehearsal";
  }

  if (/REHEARSAL/i.test(text)) {
    return text
      .replace(/\bTBD\b/gi, "")
      .replace(/\bREH\b/gi, "Rehearsal")
      .replace(/\s+/g, " ")
      .trim();
  }

  return text;
}


function buildHomeUpcomingEventDetails_(event, type) {
  event = event || {};

  const details = [];

  if (type === "rehearsal") {
    if (event.location) {
      details.push(
        "Location: " +
        event.location
      );
    }

    if (event.requiresReview) {
      details.push(
        "NEEDS REVIEW"
      );
    }
  }

  if (
    type === "performance" &&
    event.conductor
  ) {
    details.push(
      "Conductor: " +
      event.conductor
    );
  }

  return details.join(" • ");
}


function buildHomeUpcomingWhoText_(event, type) {
  event = event || {};

  let who =
    Array.isArray(event.who)
      ? event.who.slice()
      : [event.who];

  who = who
    .map(function(value) {
      return String(value || "").trim();
    })
    .filter(Boolean);

  /*
   * Remove generic Team SM from the Who column.
   * Keep named SMs or other specific calls.
   */
  if (type === "rehearsal") {
    who = who.filter(function(value) {
      return value.toUpperCase() !== "TEAM SM";
    });
  }

  return uniqueHomeUpcomingStrings_(who)
    .join(", ");
}


function buildHomeUpcomingTimeText_(startTime, endTime) {
  const start =
    normalizeHomeUpcomingTime_(
      startTime
    );

  const end =
    normalizeHomeUpcomingTime_(
      endTime
    );

  if (start && end) {
    return start + " - " + end;
  }

  return start || end;
}


function normalizeHomeUpcomingTime_(value) {
  return String(value || "")
    .trim()
    .replace(
      /(\d)(AM|PM)\b/gi,
      "$1 $2"
    )
    .replace(/\s+/g, " ");
}


function uniqueHomeUpcomingStrings_(values) {
  const seen = {};

  return (Array.isArray(values) ? values : [])
    .map(function(value) {
      return String(value || "").trim();
    })
    .filter(function(value) {
      if (!value) {
        return false;
      }

      const key =
        value.toUpperCase();

      if (seen[key]) {
        return false;
      }

      seen[key] = true;
      return true;
    });
}


/* =========================================================
 * THEME
