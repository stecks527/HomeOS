function buildUpcomingEvent_(
  type,
  startTime,
  endTime,
  title,
  who,
  sourceItem
) {
  sourceItem =
    sourceItem || {};

  return {
    type:
      type || "event",

    startTime:
      String(
        startTime || ""
      ).trim(),

    endTime:
      String(
        endTime || ""
      ).trim(),

    title:
      String(
        title || ""
      ).trim(),

    who:
      Array.isArray(who)
        ? who.filter(Boolean)
        : String(
            who || ""
          ).trim(),

    location:
      String(
        sourceItem.location || ""
      ).trim(),

    conductor:
      String(
        sourceItem.conductor || ""
      ).trim(),

    requiresReview:
      Boolean(
        sourceItem.requiresReview
      ),

    notes:
      String(
        sourceItem.notes || ""
      ).trim(),

    rehearsalPianist:
      String(
        sourceItem.rehearsalPianist || ""
      ).trim(),

    musicDirector:
      String(
        sourceItem.musicDirector || ""
      ).trim(),

    stageManagement:
      Array.isArray(
        sourceItem.stageManagement
      )
        ? sourceItem.stageManagement.filter(Boolean)
        : [],

    crewDepartments:
      Array.isArray(
        sourceItem.crewDepartments
      )
        ? sourceItem.crewDepartments.filter(Boolean)
        : []
  };
}

function buildUpcomingRehearsalTitle_(
  rehearsal
) {
  rehearsal =
    rehearsal || {};

  const rawTitle =
    String(
      rehearsal.title ||
      "Rehearsal"
    )
      .replace(/\s+/g, " ")
      .trim();

  /*
   * The WeeklyOS title is already the reviewed title.
   * Do not append pianist, music director, creative team,
   * stage management, or called people to the Event column.
   */
  return rawTitle;
}


function buildUpcomingPerformanceTitle_(
  performance
) {
  performance =
    performance || {};

  const number =
    String(
      performance
        .performanceNumber ||
      ""
    ).trim();

  if (number) {
    return (
      "Performance #" +
      number
    );
  }

  return (
    performance.label ||
    "Performance"
  );
}


function buildUpcomingPutInWho_(
  putIn
) {
  putIn =
    putIn || {};

  const people = [];

  (putIn.assignments || [])
    .forEach(
      function (assignment) {
        if (!assignment) {
          return;
        }

        const name =
          assignment.person ||
          assignment.actor ||
          assignment.name ||
          "";

        if (name) {
          people.push(
            name
          );
        }
      }
    );

  (putIn.segments || [])
    .forEach(
      function (segment) {
        (segment.called || [])
          .forEach(
            function (name) {
              people.push(
                name
              );
            }
          );
      }
    );

  return uniqueUpcomingStrings_(
    people
  );
}


/* =========================================================
 * OUTS
 * ========================================================= */

function buildUpcomingOutLines_(
  outs,
  category
) {
  return (
    Array.isArray(outs)
      ? outs
      : []
  )
    .map(
      function (item) {
        item =
          item || {};

        const person =
          item.person || "";

        const descriptor =
          category === "CREW"
            ? item.department
            : item.role;

        const coverage =
          item.coverage
            ? (
                " — " +
                item.coverage +
                " IN"
              )
            : "";

        return [
          person,
          descriptor
            ? "(" +
              descriptor +
              ")"
            : ""
        ]
          .filter(Boolean)
          .join(" ") +
          " OUT" +
          coverage;
      }
    )
    .filter(Boolean);
}


/* =========================================================
 * SORTING / FORMATTING
 * ========================================================= */

function compareUpcomingEvents_(
  a,
  b
) {
  return (
    upcomingTimeSortValue_(
      a.startTime
    ) -
    upcomingTimeSortValue_(
      b.startTime
    )
  );
}


function upcomingTimeSortValue_(
  value
) {
  const text =
    String(value || "")
      .toUpperCase()
      .trim();

  const match =
    text.match(
      /(\d{1,2})(?::(\d{2}))?\s*(AM|PM)/
    );

  if (!match) {
    return 999999;
  }

  let hour =
    Number(match[1]);

  const minute =
    Number(
      match[2] || 0
    );

  const meridiem =
    match[3];

  if (
    meridiem === "PM" &&
    hour !== 12
  ) {
    hour += 12;
  }

  if (
    meridiem === "AM" &&
    hour === 12
  ) {
    hour = 0;
  }

  return (
    hour * 60 +
    minute
  );
}


function buildUpcomingTimeText_(
  startTime,
  endTime
) {
  const start =
    String(
      startTime || ""
    ).trim();

  const end =
    String(
      endTime || ""
    ).trim();

  if (
    start &&
    end
  ) {
    return (
      start +
      "–" +
      end
    );
  }

  return start || end;
}


function uniqueUpcomingStrings_(
  values
) {
  const seen = {};

  return (
    Array.isArray(values)
      ? values
      : []
  )
    .map(
      function (value) {
        return String(
          value || ""
        ).trim();
      }
    )
    .filter(
      function (value) {
        if (!value) {
          return false;
        }

        const key =
          value.toUpperCase();

        if (seen[key]) {
          return false;
        }

        seen[key] =
          true;

        return true;
      }
    );
}


