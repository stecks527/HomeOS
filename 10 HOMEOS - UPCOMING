function getHomeUpcomingTheme_() {
  return {
    darkBlue: "#173B73",
    weeklyBlue: "#1155CC",
    linkBlue: "#0000FF",
    gold: "#FFD11A",
    headerFill: "#F3F3F3",
    borderColor: "#222222",
