/* =========================================================
 * UPCOMING DATA
 * ========================================================= */

function getDashboardUpcomingFromWeekly_() {
  const ss =
    SpreadsheetApp
      .getActiveSpreadsheet();

  const inOut =
    ss.getSheetByName(
      "IN/OUT"
    );

  if (!inOut) {
    return [];
  }

  const startDate =
    parseInOutDate_(
      inOut
        .getRange("A3")
        .getDisplayValue()
    );

  if (
    !(startDate instanceof Date) ||
    isNaN(startDate.getTime())
  ) {
    return [];
  }

  const targetDates = [];

  for (
    let offset = 1;
    offset <= 5;
    offset++
  ) {
    const date =
      new Date(
        startDate.getFullYear(),
        startDate.getMonth(),
        startDate.getDate() +
          offset
      );

    targetDates.push(
      date
    );
  }

  if (
    typeof WeeklyScheduleOS !==
      "function"
  ) {
    throw new Error(
      "Home Upcoming requires " +
      "29 WEEKLY SCHEDULE OS."
    );
  }

  const days =
    WeeklyScheduleOS()
      .getDays(
        targetDates
      );

  const ptMap =
    typeof getHomePTUpcomingMap_ ===
      "function"
      ? getHomePTUpcomingMap_(
          targetDates
        )
      : {};

  return days
    .map(
      function (day) {
        const result =
          buildDashboardUpcomingDayFromModel_(
            day
          );

        /*
         * Keep the newer external PT signup summary.
         * PT remains in its own card rather than being
         * repeated in this compact Weekly preview.
         */
        result.ptSummary =
          ptMap[
            day.date
          ] || null;

        return result;
      }
    )
    .filter(
      function (day) {
        return (
          day.dayOff ||
          day.events.length ||
          day.castChanges.length ||
          day.notes.length
        );
      }
    );
}


/* =========================================================
 * BUILD HOME DAY FROM WEEKLY MODEL
 * ========================================================= */

function buildDashboardUpcomingDayFromModel_(
  day
) {
  day =
    day || {};

  const events = [];

  /*
   * Meetings
   */
  (day.meetings || [])
    .forEach(
      function (item) {
        events.push(
          buildUpcomingEvent_(
            "meeting",
            item.startTime,
            item.endTime,
            buildUpcomingMeetingTitle_(
              item
            ),
            item.called,
            item
          )
        );
      }
    );

  /*
   * Work calls
   */
  (day.workCalls || [])
    .forEach(
      function (item) {
        events.push(
          buildUpcomingEvent_(
            "work_call",
            item.startTime,
            item.endTime,
            item.title ||
              "Work Call",
            item.called,
            item
          )
        );
      }
    );

  /*
   * Rehearsals
   */
  (day.rehearsals || [])
    .filter(
      function (item) {
        return !item.canceled;
      }
    )
    .forEach(
      function (item) {
        events.push(
          buildUpcomingEvent_(
            "rehearsal",
            item.startTime,
            item.endTime,
            buildUpcomingRehearsalTitle_(
              item
            ),
            item.called,
            item
          )
        );
      }
    );

  /*
   * Put-ins
   */
  (day.putIns || [])
    .forEach(
      function (item) {
        events.push(
          buildUpcomingEvent_(
            "put_in",
            item.startTime,
            item.endTime,
            item.title ||
              "Put-In",
            buildUpcomingPutInWho_(
              item
            ),
            item
          )
        );
      }
    );

  /*
   * Company events
   */
  (day.companyEvents || [])
    .forEach(
      function (item) {
        events.push(
          buildUpcomingEvent_(
            "company_event",
            item.startTime,
            item.endTime,
            item.title ||
              "Company Activity",
            item.people,
            item
          )
        );
      }
    );

  /*
   * Performances
   */
  (day.performances || [])
    .forEach(
      function (item) {
        events.push(
          buildUpcomingEvent_(
            "performance",
            item.time,
            "",
            buildUpcomingPerformanceTitle_(
              item
            ),
            "Full Company",
            item
          )
        );
      }
    );

  events.sort(
    compareUpcomingEvents_
  );

  const castChanges =
    []
      .concat(
        buildUpcomingOutLines_(
          day.castOuts,
          "CAST"
        )
      )
      .concat(
        buildUpcomingOutLines_(
          day.crewOuts,
          "CREW"
        )
      );

  const notes =
    []
      .concat(
        (day.holidays || [])
          .map(
            function (item) {
              return (
                item.title ||
                item.notes ||
                ""
              );
            }
          )
      )
      .concat(
        (day.notes || [])
          .map(
            function (item) {
              return (
                item.text ||
                ""
              );
            }
          )
      )
      .filter(Boolean);

  return {
    date:
      day.date || "",

    dateLabel:
      day.dateLabel || "",

    dayOff:
      day.dayOff || null,

    events:
      events,

    castChanges:
      castChanges,

    notes:
      uniqueUpcomingStrings_(
        notes
      ),

    source:
      day.source || ""
  };
}
